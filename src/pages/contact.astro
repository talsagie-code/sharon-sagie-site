---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
const c = site.contact;
const methods = c.methods;
const nl = (t) => t.replace(/\n/g, '<br/>');
---
<Base active="contact" solidNav={true} title="צרו קשר · שרון שגיא">
  <header class="page-head reveal">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1 set:html={nl(c.title)}></h1>
    <p>{c.lead}</p>
  </header>

  <section class="wrap contact">
    <div class="c-methods">
      {methods.map((m) => (
        <a class={`c-method reveal${m.href ? ' is-link' : ''}`} href={m.href || undefined}>
          <span class="c-line"></span>
          <div class="c-label">{m.label}</div>
          <div class="c-value">
            {m.href && m.href.includes('wa.me') && (
              <svg class="wa-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm5.8 14.18c-.25.69-1.45 1.32-1.99 1.36-.51.04-1.16.06-1.87-.12-.43-.11-.99-.3-1.7-.61-2.99-1.29-4.95-4.3-5.1-4.5-.15-.2-1.22-1.62-1.22-3.1 0-1.48.78-2.2 1.05-2.5.27-.3.59-.37.79-.37.2 0 .39 0 .56.01.18.01.42-.07.66.5.25.59.84 2.04.91 2.19.07.15.12.32.02.52-.1.2-.15.32-.3.5-.15.18-.31.4-.44.53-.15.15-.3.31-.13.6.17.29.76 1.25 1.63 2.03 1.12 1 2.06 1.31 2.35 1.46.29.15.46.12.63-.07.17-.2.73-.85.92-1.14.2-.29.39-.24.66-.15.27.1 1.71.81 2 .96.29.15.49.22.56.34.07.12.07.69-.18 1.38z"/></svg>
            )}
            <span class="c-text">{m.value}</span>
          </div>
        </a>
      ))}
    </div>
    <div class="c-social reveal">
      <a href="https://instagram.com/two_studio_interior_design" target="_blank" rel="noopener">Instagram</a>
      <span class="dot">·</span>
      <a href="https://www.facebook.com/profile.php?id=100076946022571" target="_blank" rel="noopener">Facebook</a>
    </div>
  </section>
</Base>

<style>
  .contact{padding:4vh 0 14vh}
  .c-methods{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;max-width:780px;margin:0 auto}
  .c-method{display:block;background:#fff;border:1px solid var(--line);border-radius:6px;padding:38px 28px;text-align:center;transition:.4s}
  a.c-method:hover{transform:translateY(-3px);box-shadow:0 18px 44px rgba(38,32,25,.1);border-color:var(--accent)}
  .c-line{display:block;width:30px;height:2px;background:var(--accent);opacity:.85;margin:0 auto 20px}
  .c-label{font-size:.78rem;letter-spacing:.22em;color:var(--ink-soft)}
  .c-value{font-family:var(--serif);font-size:1.25rem;margin-top:12px;font-weight:500;line-height:1.5;display:flex;align-items:center;justify-content:center;gap:9px;flex-wrap:wrap;overflow-wrap:anywhere}
  .c-method.is-link .c-text{color:var(--accent-deep);text-decoration:underline;text-decoration-color:rgba(174,90,60,.45);text-underline-offset:4px;transition:.3s}
  a.c-method.is-link:hover .c-text{text-decoration-color:var(--accent)}
  .wa-ic{width:25px;height:25px;color:#25D366;flex:0 0 auto}
  .c-social{display:flex;gap:14px;justify-content:center;align-items:center;margin-top:42px;color:var(--accent-deep);font-size:1rem;letter-spacing:.04em}
  .c-social .dot{opacity:.5}
  @media(max-width:680px){.c-methods{grid-template-columns:1fr}}
</style>
