---
import Base from '../layouts/Base.astro';

// ── Lead form backend ──────────────────────────────────────────────
// Paste the Google Apps Script Web App URL here after deploying it
// (see MAKE-IT-EASY-FORM-SETUP.md). Until then the form shows a
// friendly message but won't record leads.
const FORM_ENDPOINT = 'PASTE_APPS_SCRIPT_URL_HERE';

// The smoove landing tool blocks its images from loading on other domains,
// so these are self-hosted site photos as placeholders. Swap to the exact
// originals (before/afters + Sharon's landing portrait) once provided.
const img = {
  materials: '/uploads/projects/broshim-apartment/03.webp',
  collage: '/uploads/projects/kids-kingdom/02.webp',
  ba1: '/uploads/projects/duplex-nesher/01.webp',
  ba2: '/uploads/projects/red-meat-offices/01.webp',
  ba3: '/uploads/projects/kids-kingdom/01.webp',
  ba4: '/uploads/projects/broshim-apartment/01.webp',
  profile: '/assets/home-portrait.webp',
};

const included = [
  { t: 'פגישת ייעוץ של שעתיים בביתך', p: 'אגיע אליכם הביתה עם מזוודת חומרים — מניפות צבע, פורמייקה ועוד. נבין יחד את הסגנון שמתאים לכם ולאורח חייכם, נעבור על החללים ונחשוב כיצד לשנות אותם בעזרת בחירה נכונה של צבע, חומר, טקסטיל וריהוט. אמליץ גם כיצד למקם נכון את הריהוט הקיים והחדש.', icon: 'suitcase' },
  { t: 'לוח השראה', p: 'לאחר הפגישה אכין לוח השראה בהתאם לסגנון האהוב עליכם. הלוח ימקד אותנו ביום הרכישות ויעזור לכם להמשיך לעצב את הבית בכוחות עצמכם.', icon: 'board' },
  { t: 'תכנון תקציב', p: 'בהתאם לתקציב שלכם אחלק אותו נכון בין הרכישות שיש לבצע — עוד דרך לייעל את יום הרכישות ולחסוך זמן וכסף.', icon: 'wallet' },
  { t: 'יום רכישות משותף', p: 'בהתאם לסגנון, לצרכים ולתקציב אתכנן יום רכישות של 4 שעות בחנויות המתאימות, כדי שנקנה בדיוק את מה שצריך — בלי בלבול ובלי בזבוז.', icon: 'bag' },
  { t: 'סיכום מפורט של הפגישות', p: 'לאחר יום הרכישות תקבלו מסמך מפורט המסכם את כל ההמלצות, הרעיונות וההנחיות ליישום — כך שתוכלו בקלות לבצע לבד את כל מה שתכננו יחד.', icon: 'doc' },
  { t: 'המשך ליווי לשבועיים', p: 'גם אחרי יום הרכישות אני איתכם — ממשיכה לייעץ ולהנחות בוואטסאפ ובמייל, כדי שתרגישו בטוחים ולא תצטרכו להתלבט לבד, גם ברכישות נוספות.', icon: 'chat' },
  { t: 'בונוס: רשימת ספקים ובעלי מקצוע', p: 'רשימת בעלי מקצוע, ספקים, חנויות ואתרים שיעזרו לכם להשלים את המהפך בעצמכם.', icon: 'gift' },
];

const faqs = [
  { q: 'למי מתאים המסלול?', a: 'למי שרוצה לרענן, לשדרג או לשנות ייעוד ל־2־3 חדרים או אזורים בבית.' },
  { q: 'האם המסלול מתאים גם לדירה שכורה?', a: 'בוודאי! כל שינוי שנעשה הוא הפיך (הרי לא שוברים קירות), ואת הריהוט תוכלי לקחת איתך — כך שזה אפילו מומלץ, כדי שגם בדירה שכורה תרגישי בבית.' },
  { q: 'האם שעתיים מספיקות לכל הבית?', a: 'שעתיים מספיקות לרוב למקסימום שניים־שלושה חדרים או אזורים. אם מדובר בבית שלם, אפשר להוסיף שעה בתשלום נוסף של 350 ₪, או לבחור במסלול הליווי המלא להלבשת הבית — תלוי בגודל הבית ובהיקף השינוי.' },
  { q: 'היכן מתקיים יום הרכישות?', a: 'באזור חיפה והקריות.' },
  { q: 'האם יום הרכישות יכול להתקיים ביום שישי?', a: 'לא, ימי הפעילות של הסטודיו הם ראשון־חמישי, 9:00–18:00.' },
  { q: 'האם 4 שעות ליום רכישות יספיקו?', a: 'נגיע ליום הרכישות אחרי תעדוף הרכישות (לפי דחיפות ותקציב), ואבנה את היום כך שנדע בדיוק לאילו חנויות הולכים — כך שהוא יהיה יעיל מאוד. אם תרצו בכל זאת להוסיף שעה, אפשר לתאם מראש בתוספת תשלום.' },
  { q: 'מה התקציב המומלץ ליישום ההמלצות?', a: 'כל בית ומשפחה שונים, אך ברוב המקרים, כדי ליצור שינוי משמעותי בכמה חדרים או אזורים, אני ממליצה על תקציב של לפחות 40,000–50,000 ₪ לרכישות ולרענון הבית (כולל צביעה). אם התקציב נמוך יותר, נוכל להתמקד בחלק מההמלצות או להתאים מסלול אחר.' },
];
---

<Base active="" solidNav={true} title="Make it Easy · שרון שגיא" description="הפתרון המושלם למי שרוצה לרענן ולשדרג את הבית בתהליך קצר, יעיל וממוקד — בשתי פגישות בלבד.">
  <!-- HERO -->
  <header class="me-hero">
    <div class="me-hero__in">
      <span class="me-eyebrow">Make it easy</span>
      <h1>מרגישה שאת גרה בין ארבעה קירות,<br/>ולא בבית שאת באמת רוצה?</h1>
      <p class="me-hero__lead">יש לי פתרון שיגרום לך להתאהב בבית שלך — בתהליך ממוקד ויעיל, שיחסוך לך הרבה זמן וכסף.</p>
      <a href="#lead" class="me-btn">אני רוצה להתחיל</a>
    </div>
  </header>

  <!-- PAIN -->
  <section class="me-sec me-pain wrap">
    <div class="me-pain__txt reveal">
      <p>אם <b>חדר השינה</b> שלך לא מזמין ולא עושה חשק להיכנס אליו בסוף יום עמוס,</p>
      <p>אם הבת שלך גדלה וכבר <b>רוצה חדר מעוצב של נערה</b>,</p>
      <p>אם את חוזרת מהעבודה <b>והבית לא מטעין אותך באנרגיה</b>,</p>
      <p>אם את חולמת <b>על בית חמים ונעים</b> שכיף לארח בו — אבל פשוט לא יודעת מאיפה להתחיל…</p>
      <p class="me-muted">משוטטת שעות באינסטגרם ובפינטרסט, שומרת תמונות של עיצובים שאהבת — אבל שם זה נעצר. אולי חיפשת ריהוט בחנויות, אבל המגוון רק בלבל, וחזרת בידיים ריקות. אולי הזמנת פריטים או בחרת צבע, ובסוף שום דבר לא התחבר — והרגשת שסתם בזבזת זמן וכסף.</p>
      <p class="me-lead-line">את כבר מבינה שאת צריכה <b>עין מקצועית של מעצבת פנים</b> — אבל ממש לא בא לך להיכנס לתהליך ארוך ויקר.</p>
    </div>
    <div class="me-pain__img reveal"><img src={img.materials} alt="פגישת ייעוץ עיצובי בבית" loading="lazy" /></div>
  </section>

  <!-- PROMISE -->
  <section class="me-promise">
    <div class="wrap reveal">
      <p>אני יודעת כמה עיצוב הבית משפיע על <b>איכות החיים</b> — פיזית ומנטלית. לכן יצרתי שירות שלא מצריך שבירת קירות: <b>ממוקד, יעיל, ובלי עלויות גבוהות</b> — ועדיין משדרג את הבית ואת החיים בו תוך זמן קצר.</p>
      <p class="me-big">והכל בשתי פגישות בלבד.</p>
      <p>פתאום הכל מתחבר, ונראה הרבה יותר פשוט וקל.</p>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="me-sec wrap">
    <h2 class="me-h">מה אומרים הלקוחות על התהליך?</h2>
    <p class="me-sub">אין דבר משמח יותר מלראות לקוחות שהגיעו מבולבלים מרוב אפשרויות — ויצאו עם בית שמרגיש בדיוק שלהם.</p>
    <div class="me-collage reveal"><img src={img.collage} alt="המלצות לקוחות" loading="lazy" /></div>
    <p class="me-note">ההמלצות נאספו מפגישות ייעוץ שבוצעו במסגרת השותפות ב־two studio.</p>
  </section>

  <!-- BEFORE / AFTER -->
  <section class="me-sec wrap">
    <h2 class="me-h">ואיך נראה השינוי אצלם?</h2>
    <div class="me-ba">
      <img src={img.ba1} alt="לפני ואחרי" loading="lazy" />
      <img src={img.ba2} alt="לפני ואחרי" loading="lazy" />
      <img src={img.ba3} alt="לפני ואחרי" loading="lazy" />
      <img src={img.ba4} alt="לפני ואחרי" loading="lazy" />
    </div>
    <p class="me-note">התמונות מפרויקטים שבוצעו במסגרת two studio.</p>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="me-included">
    <div class="wrap">
      <h2 class="me-h">אז מה בעצם המסלול כולל?</h2>
      <p class="me-sub"><b>Make it easy</b> — שתי פגישות שיגרמו לך להתאהב בבית שלך, בקלות.</p>
      <div class="me-grid">
        {included.map((s, i) => (
          <div class="me-card reveal">
            <div class="me-ic" set:html={`<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'>${{
              suitcase: `<rect x='3' y='7' width='18' height='13' rx='2'/><path d='M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2'/><path d='M3 13h18'/>`,
              board: `<rect x='3' y='3' width='18' height='18' rx='2'/><path d='M3 9h18M9 21V9'/>`,
              wallet: `<rect x='3' y='6' width='18' height='13' rx='2'/><path d='M3 10h18'/><circle cx='16.5' cy='13.5' r='1'/>`,
              bag: `<path d='M6 8h12l-1 12H7L6 8z'/><path d='M9 8a3 3 0 0 1 6 0'/>`,
              doc: `<path d='M6 2h9l3 3v17H6z'/><path d='M9 8h6M9 12h6M9 16h4'/>`,
              chat: `<path d='M4 5h16v11H9l-5 4V5z'/><path d='M8 10h8M8 13h5'/>`,
              gift: `<rect x='3' y='9' width='18' height='12' rx='1'/><path d='M3 13h18M12 9v12'/><path d='M12 9S9 3 6.5 4.5 9 9 12 9zM12 9s3-6 5.5-4.5S15 9 12 9z'/>`,
            }[s.icon]}</svg>`}></div>
            <span class="me-num">{String(i + 1).padStart(2, '0')}</span>
            <h4>{s.t}</h4>
            <p>{s.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICE -->
  <section class="me-price">
    <div class="wrap reveal">
      <span class="me-eyebrow">המחיר ל־Make it easy</span>
      <div class="me-price__num">4,200 <span>₪</span></div>
      <p>אני יכולה להבטיח לך שזו תהיה אחת ההוצאות המשתלמות שתעשי.</p>
      <p class="me-price__note">אני מקבלת רק שתי לקוחות בחודש למסלול הזה — אז אם חשוב לך להתחיל כבר בתהליך, השאירי פרטים ואחזור אלייך לשיחת התאמה.</p>
      <a href="#lead" class="me-btn me-btn--light">אני רוצה להשאיר פרטים</a>
    </div>
  </section>

  <!-- LEAD FORM -->
  <section class="me-lead" id="lead">
    <div class="wrap">
      <h2 class="me-h">מלאי כאן את הפרטים ואחזור אלייך</h2>
      <p class="me-sub">לשיחת התאמה קצרה. שעות הפעילות: א'–ה', 9:00–18:00.</p>
      <form class="me-form" id="meForm">
        <div class="me-row">
          <label>שם פרטי<input type="text" name="first" required autocomplete="given-name" /></label>
          <label>שם משפחה<input type="text" name="last" required autocomplete="family-name" /></label>
        </div>
        <div class="me-row">
          <label>מייל<input type="email" name="email" required autocomplete="email" dir="ltr" /></label>
          <label>נייד<input type="tel" name="phone" required autocomplete="tel" dir="ltr" /></label>
        </div>
        <button type="submit" class="me-btn me-form__btn">אני כבר רוצה להתאהב בבית שלי!</button>
        <p class="me-form__msg" id="meMsg" hidden></p>
      </form>
    </div>
  </section>

  <!-- FAQ -->
  <section class="me-sec wrap">
    <h2 class="me-h">שאלות שאולי עלו לך</h2>
    <div class="me-faq">
      {faqs.map((f) => (
        <details class="me-q">
          <summary>{f.q}<span class="me-q__mark" aria-hidden="true">+</span></summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
    <div class="me-faq__cta"><a href="#lead" class="me-btn">מתאים לי — אשאיר פרטים</a></div>
  </section>

  <!-- ABOUT -->
  <section class="me-about">
    <div class="wrap me-about__in">
      <div class="me-about__img reveal"><img src={img.profile} alt="שרון שגיא" loading="lazy" /></div>
      <div class="me-about__txt reveal">
        <span class="me-eyebrow">נעים להכיר</span>
        <h2 class="me-h">אני שרון שגיא</h2>
        <p>מעצבת פנים המתמחה בתכנון וליווי שיפוצים ובתים בבנייה. עוד כילדה נמשכתי לעולם הזה — הייתי משנה שוב ושוב את סידור החדר שלי.</p>
        <p>לפני עיצוב הפנים עסקתי בייעוץ גנטי — תחום שלימד אותי להקשיב, לחשוב לעומק, לראות את התמונה המלאה ולשים לב לכל פרט קטן. היום אני מביאה בדיוק את אותה גישה לתכנון בתים.</p>
        <p>אני מאמינה שבית טוב מתחיל הרבה לפני בחירת הצבעים — הוא מתחיל בתכנון מדויק, בהבנת הצרכים וההרגלים של המשפחה, וביצירת פתרונות חכמים שמאפשרים לבית לעבוד באמת ביום־יום. אז בואי נצא לדרך יחד.</p>
      </div>
    </div>
  </section>

  <style>
    .me-btn{display:inline-block;background:var(--accent);color:#fff;border:1px solid var(--accent);padding:15px 40px;border-radius:50px;font-size:1.02rem;letter-spacing:.02em;cursor:pointer;transition:.3s}
    @media (hover:hover){.me-btn:hover{background:var(--accent-deep);border-color:var(--accent-deep)}}
    .me-btn--light{background:#fff;color:var(--accent-deep);border-color:#fff}
    @media (hover:hover){.me-btn--light:hover{background:var(--bg-2);color:var(--accent-deep)}}
    .me-eyebrow{font-family:var(--lat);font-style:italic;color:var(--accent-deep);font-size:1.1rem;letter-spacing:.04em}
    .me-h{font-family:var(--serif);font-weight:300;font-size:clamp(1.9rem,4.5vw,3rem);line-height:1.1;color:var(--ink);text-align:center}
    .me-sub{text-align:center;color:var(--ink-soft);max-width:60ch;margin:14px auto 0;font-size:1.1rem}
    .me-note{text-align:center;color:var(--ink-soft);opacity:.75;font-size:.85rem;margin-top:22px}
    .me-muted{color:var(--ink-soft)}
    .me-sec{padding:8vh 0}

    /* hero */
    .me-hero{background:var(--band);padding:22vh var(--pad) 14vh;text-align:center}
    .me-hero__in{max-width:900px;margin:0 auto}
    .me-hero h1{font-family:var(--serif);font-weight:300;font-size:clamp(2.1rem,5.4vw,3.7rem);line-height:1.14;margin:16px 0 0;color:var(--ink)}
    .me-hero__lead{font-size:clamp(1.1rem,2.2vw,1.4rem);color:#5a4433;max-width:44ch;margin:22px auto 34px;line-height:1.7}

    /* pain */
    .me-pain{display:grid;grid-template-columns:1.15fr .85fr;gap:clamp(30px,5vw,70px);align-items:center}
    .me-pain__txt p{font-size:1.12rem;line-height:1.9;margin-bottom:.8em;color:var(--ink)}
    .me-pain__txt b{font-weight:500;color:var(--accent-deep)}
    .me-lead-line{font-family:var(--serif);font-size:1.3rem!important;margin-top:.6em}
    .me-pain__img img{width:100%;border-radius:4px;aspect-ratio:4/5;object-fit:cover;box-shadow:0 24px 55px rgba(38,32,25,.16)}

    /* promise */
    .me-promise{background:var(--accent-deep);color:#f6ece7;text-align:center;padding:12vh 0}
    .me-promise p{max-width:60ch;margin:0 auto 1em;font-size:1.2rem;line-height:1.8}
    .me-promise b{color:#fff;font-weight:500}
    .me-big{font-family:var(--serif);font-size:clamp(1.8rem,4vw,2.6rem)!important;color:#fff;margin:.4em auto!important}

    /* testimonials + before/after */
    .me-collage{margin:34px auto 0;max-width:820px}
    .me-collage img,.me-ba img{width:100%;border-radius:4px;display:block}
    .me-ba{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:34px}

    /* included */
    .me-included{background:var(--bg-2);padding:11vh 0}
    .me-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-top:52px}
    .me-card{position:relative;background:#fff;border:1px solid #E8D7CD;border-radius:6px;padding:34px 28px}
    .me-ic{width:44px;height:44px;color:var(--accent)}
    .me-ic svg{width:100%;height:100%}
    .me-num{position:absolute;top:24px;inset-inline-start:26px;font-family:var(--lat);font-style:italic;color:var(--accent);opacity:.35;font-size:1.5rem}
    .me-card h4{font-family:var(--serif);font-weight:500;font-size:1.35rem;margin:18px 0 .5em;color:var(--ink)}
    .me-card p{color:var(--ink-soft);line-height:1.75;font-size:.98rem}

    /* price */
    .me-price{background:var(--accent);color:#fff;text-align:center;padding:12vh var(--pad)}
    .me-price .me-eyebrow{color:#f4d9cd}
    .me-price__num{font-family:var(--serif);font-size:clamp(3.4rem,9vw,5.5rem);line-height:1;margin:10px 0 18px}
    .me-price__num span{font-size:.4em;vertical-align:middle}
    .me-price p{max-width:52ch;margin:0 auto 1em;font-size:1.12rem;line-height:1.7}
    .me-price__note{opacity:.92;font-size:1rem!important}
    .me-price .me-btn--light{margin-top:16px}

    /* lead form */
    .me-lead{padding:12vh 0;background:var(--bg)}
    .me-form{max-width:620px;margin:40px auto 0}
    .me-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px}
    .me-form label{display:flex;flex-direction:column;gap:8px;font-size:.9rem;color:var(--ink-soft)}
    .me-form input{border:1px solid #d9c8bb;background:#fff;border-radius:6px;padding:13px 15px;font-family:inherit;font-size:1rem;color:var(--ink);transition:.2s}
    .me-form input:focus{outline:none;border-color:var(--accent)}
    .me-form__btn{width:100%;margin-top:8px;border:none;font-size:1.05rem}
    .me-form__msg{text-align:center;margin-top:18px;font-size:1.05rem;color:var(--accent-deep)}

    /* faq */
    .me-faq{max-width:760px;margin:44px auto 0}
    .me-q{border-bottom:1px solid #e2d3c8}
    .me-q summary{list-style:none;cursor:pointer;padding:20px 0;font-family:var(--serif);font-size:1.2rem;color:var(--ink);display:flex;justify-content:space-between;align-items:center;gap:18px}
    .me-q summary::-webkit-details-marker{display:none}
    .me-q__mark{color:var(--accent);font-size:1.5rem;transition:.3s;flex:0 0 auto}
    .me-q[open] .me-q__mark{transform:rotate(45deg)}
    .me-q p{color:var(--ink-soft);line-height:1.8;padding:0 0 22px;margin:0}
    .me-faq__cta{text-align:center;margin-top:40px}

    /* about */
    .me-about{background:var(--band);padding:12vh 0}
    .me-about__in{display:grid;grid-template-columns:.8fr 1.2fr;gap:clamp(30px,5vw,64px);align-items:center}
    .me-about__img img{width:100%;border-radius:4px;aspect-ratio:4/5;object-fit:cover;box-shadow:0 24px 55px rgba(38,32,25,.18)}
    .me-about__txt .me-h{text-align:right;margin-top:6px}
    .me-about__txt p{color:#5a4433;line-height:1.9;margin-top:1em;font-size:1.05rem}

    @media(max-width:820px){
      .me-pain,.me-about__in{grid-template-columns:1fr}
      .me-pain__img{order:-1}
      .me-grid{grid-template-columns:1fr}
      .me-ba{grid-template-columns:1fr}
      .me-row{grid-template-columns:1fr}
      .me-hero{padding-top:18vh}
    }
  </style>

  <script define:vars={{ FORM_ENDPOINT }}>
    const form = document.getElementById('meForm');
    const msg = document.getElementById('meMsg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]');
      const data = new URLSearchParams(new FormData(form));
      data.append('source', 'Make it Easy');
      const show = (t, ok) => { msg.hidden = false; msg.textContent = t; msg.style.color = ok ? 'var(--accent-deep)' : '#b23b3b'; };
      if (!FORM_ENDPOINT || FORM_ENDPOINT.startsWith('PASTE_')) {
        show('הטופס עדיין לא חובר לשליחה. (צריך להזין את כתובת ה־Apps Script).', false);
        return;
      }
      btn.disabled = true; btn.textContent = 'שולח…';
      try {
        await fetch(FORM_ENDPOINT, { method: 'POST', mode: 'no-cors', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: data.toString() });
        form.reset();
        show('תודה! קיבלתי את הפרטים ואחזור אלייך בהקדם 💜', true);
      } catch (err) {
        show('אופס, משהו השתבש. אפשר לנסות שוב או לכתוב לי בוואטסאפ.', false);
      } finally {
        btn.disabled = false; btn.textContent = 'אני כבר רוצה להתאהב בבית שלי!';
      }
    });
  </script>
</Base>
