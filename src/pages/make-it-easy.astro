---
import Base from '../layouts/Base.astro';

// Lead form backend – paste the Google Apps Script Web App URL here after
// deploying it (see MAKE-IT-EASY-FORM-SETUP.md).
const FORM_ENDPOINT = 'https://docs.google.com/forms/d/1ALr3_Zbn9YqXLs1scqyP25l5P8bvXFc6KYg3wvhwEuQ/formResponse';

// Original landing-page images (served from Sharon's smoove CDN – they load fine hotlinked)
const CDN = 'https://content.vp4.me/sharon1976/Content';
const img = {
  materials: `${CDN}/IMG_7936.jpeg`,
  collage: `${CDN}/Gray%20dancer%20photo%20collage.png`,
  ba: [
    `${CDN}/18_900x450-r.jpg`,
    `${CDN}/before_after_smoove_optimized.jpg`,
    `${CDN}/before_after2_smoove_optimized.jpg`,
    `${CDN}/before_after3_smoove_optimized.jpg`,
  ],
  board: '/uploads/make-it-easy/mood-board.webp',
  budget: `${CDN}/5_480x384-r%281%29.jpg`,
  shopping: `${CDN}/%d7%a8%d7%9b%d7%99%d7%a9%d7%95%d7%aa_480x384-r.jpg`,
  summary: `${CDN}/%d7%9b%d7%a8%d7%99%d7%9b%d7%94%20%d7%a4%d7%92%d7%99%d7%a9%d7%aa%20%d7%99%d7%a2%d7%95%d7%a5.png`,
  follow: `${CDN}/Gray%20dancer%20photo%20collage%20%286%29_480x384-r.jpg`,
  profile: `${CDN}/profile_dark_optimized_smoove.jpg`,
};

const meetings = [
  { t: 'פגישת ייעוץ של שעתיים בביתך', p: 'אגיע אליכם הביתה עם מזוודת חומרים הכוללת מניפות צבע, פורמייקה ועוד. אבין מהו הסגנון העיצובי המתאים לכם ולאורח חייכם. נעבור על החללים אותם אתם מעוניינים לעצב ונחשוב יחד כיצד ניתן לשנות את החלל על ידי בחירה נכונה של צבע, חומר, טקסטיל וריהוט מתאימים. אמליץ כיצד למקם את הריהוט הקיים והחדש שתרכשו בצורה נכונה.', img: img.materials },
  { t: 'לוח השראה', p: 'לאחר הפגישה אכין לוח השראה בהתאם לסגנון האהוב עליכם. לוח זה ימקד אותנו ביום הרכישות, וגם יעזור לך להמשיך לעצב את הבית בכוחות עצמך.', img: img.board },
  { t: 'תכנון תקציב', p: 'בהתאם לתקציב העומד לרשותכם, אעשה חלוקה של התקציב בהתאם לרכישות שיש לבצע. זו עוד דרך לייעל את יום הרכישות ולחסוך זמן – וכמובן כסף!', img: img.budget },
  { t: 'יום רכישות משותף', p: 'בהתאם לסגנון, לצרכים שלכם ולתקציב, אתכנן יום רכישות של 4 שעות בחנויות המתאימות.', img: img.shopping },
];
const after = [
  { t: 'סיכום מפורט של הפגישות', p: 'לאחר יום הרכישות תקבלי מסמך מפורט המסכם את כל ההמלצות, הרעיונות וההנחיות ליישום, כך שתוכלי בקלות לבצע לבד את כל מה שתכננו יחד.', img: img.summary, fit: 'contain' },
  { t: 'המשך ליווי לשבועיים נוספים', p: 'לאחר יום הרכישות אמשיך לייעץ ולהנחות אותך בוואטסאפ ובמייל, כדי שתרגישי בטוחה ולא תצטרכי להתלבט לבד – גם אם תעשי רכישות נוספות בלעדיי.', img: img.follow },
  { t: 'ובונוס שווה ממני', p: 'רשימת בעלי מקצוע, ספקים, חנויות ואתרים שיעזרו לך להשלים את המהפך בעצמך.', img: null, icon: 'gift' },
];

const faqs = [
  { q: 'למי מתאים המסלול?', a: 'המסלול מתאים למי שרוצה לרענן ולשדרג, או לשנות ייעוד, ל־2־3 חדרים או אזורים בבית.' },
  { q: 'האם המסלול מתאים גם לדירה שכורה?', a: 'בוודאי! כל שינוי שנעשה הוא הפיך (הרי לא שוברים קירות), ואת הריהוט תוכלי להעביר איתך – כך שזה אפילו מומלץ, כדי שגם בדירה שכורה תרגישי בית.' },
  { q: 'האם שעתיים מספיקות לכל הבית?', a: 'שעתיים מספיקות לרוב למקסימום שניים־שלושה חדרים או אזורים. אם מדובר בבית שלם, אפשר להוסיף שעה בתשלום נוסף של 350 ₪, או לבחור במסלול הליווי המלא להלבשת הבית – תלוי בגודל הבית ובהיקף השינוי הנדרש.' },
  { q: 'היכן מתקיים יום הרכישות?', a: 'יום הרכישות מתקיים באזור חיפה והקריות.' },
  { q: 'האם יום הרכישות יכול להתקיים ביום שישי?', a: 'לא, ימי הפעילות של הסטודיו הם ראשון־חמישי, 9:00–18:00.' },
  { q: 'האם 4 שעות ליום רכישות יספיקו לנו?', a: 'נגיע ליום הרכישות אחרי תעדוף הרכישות (מבחינת דחיפות ותקציב), ואבנה את היום בהתאם – כך שנדע בדיוק לאילו חנויות הולכים לפי הסגנון והתקציב, והוא יהיה יעיל מאוד. אם בכל זאת תרצו להוסיף שעה נוספת, אפשר לתאם זאת מראש בתוספת תשלום.' },
  { q: 'מה התקציב המומלץ ליישום ההמלצות?', a: 'כל בית וכל משפחה שונים בצרכים שלהם, אך ברוב המקרים, כדי ליצור שינוי משמעותי במספר חדרים או אזורים בבית, אני ממליצה להגיע עם תקציב של לפחות 40,000–50,000 ₪ לרכישות ולרענון הבית (צביעה למשל). אם התקציב נמוך יותר, ייתכן שנבחר להתמקד רק בחלק מההמלצות, או להתאים עבורכם מסלול אחר.' },
];
---

<Base active="" solidNav={true} title="Make it Easy · שרון שגיא" description="הפתרון המושלם למי שרוצה לרענן ולשדרג את הבית בתהליך קצר, יעיל וממוקד – בשתי פגישות בלבד.">
  <!-- HERO -->
  <header class="me-hero">
    <div class="me-hero__in">
      <h1>מרגישה שאת גרה בין ארבעה קירות,<br/>ולא בבית שאת באמת רוצה?</h1>
      <p class="me-hero__lead">יש לי פתרון מושלם שיגרום לך להתאהב בבית שלך – בתהליך ממוקד ויעיל, שיחסוך לך הרבה זמן וכסף!</p>
      <a href="#lead" class="me-btn">אני רוצה להתחיל</a>
    </div>
  </header>

  <!-- PAIN -->
  <section class="me-sec me-pain wrap">
    <div class="me-pain__txt reveal">
      <p>אם <b>חדר השינה שלך לא מזמין</b> ולא עושה לך חשק להיכנס אליו בסוף יום עמוס,</p>
      <p>או שהבת שלך גדלה וכבר <b>רוצה חדר מעוצב של נערה</b>,</p>
      <p>אם את חוזרת הביתה מהעבודה <b>והבית לא מטעין אותך באנרגיה</b>,</p>
      <p>אם את חולמת <b>על בית חמים ונעים</b> שכיף לארח בו – אבל פשוט לא יודעת מאיפה להתחיל…</p>
      <p class="me-muted">את משוטטת שעות באינסטגרם ובפינטרסט, שומרת תמונות של עיצובים שאהבת – אבל שם זה נעצר.</p>
      <p class="me-muted">אולי אפילו חיפשת ריהוט ואקססוריז בחנויות, אבל המגוון הענק רק בלבל אותך יותר, וחזרת הביתה בידיים ריקות.</p>
      <p class="me-muted">אולי גם הזמנת פריטים אונליין או בחרת צבע לבית, ובסוף ראית ששום דבר לא מתחבר ולא מתאים – והרגשת כל כך מתוסכלת מזה שסתם בזבזת זמן וכסף.</p>
      <p class="me-lead-line">את כבר כנראה מבינה שאת צריכה <b>עין מקצועית של מעצבת פנים</b> – אבל ממש לא בא לך להיכנס לתהליך ארוך ויקר.</p>
    </div>
    <div class="me-pain__img reveal"><img src={img.materials} alt="פגישת ייעוץ עיצובי בבית" loading="lazy" /></div>
  </section>

  <!-- PROMISE -->
  <section class="me-promise">
    <div class="wrap reveal">
      <p>אני מבינה כמה עיצוב הבית משפיע על <b>איכות החיים</b> – מבחינה פיזית ומנטלית. לכן היה חשוב לי ליצור שירות שלא מצריך שבירת קירות: <b>שירות ממוקד ויעיל</b>, שלא כרוך בעלויות גבוהות, ועדיין ישדרג את הבית ואת החיים בו תוך זמן קצר –</p>
      <p class="me-big">בשתי פגישות בלבד!</p>
      <p>פתאום הכל יתחבר, וייראה הרבה יותר פשוט וקל.</p>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="me-sec wrap">
    <h2 class="me-h">מה אומרים הלקוחות על התהליך?</h2>
    <p class="me-sub">אין דבר יותר משמח מלראות לקוחות שהגיעו לפגישה מבולבלים מרוב אפשרויות והחלטות – ויצאו עם בית שמרגיש בדיוק שלהם.</p>
    <p class="me-note me-note--top">ההמלצות נאספו מפגישות ייעוץ שבוצעו במסגרת השותפות ב־Two studio.</p>
    <div class="me-collage reveal"><img src={img.collage} alt="המלצות לקוחות" loading="lazy" /></div>
  </section>

  <!-- BEFORE / AFTER -->
  <section class="me-sec wrap">
    <h2 class="me-h">ואיך נראה השינוי אצלם?</h2>
    <div class="me-ba">
      {img.ba.map((src) => (<img src={src} alt="לפני ואחרי" loading="lazy" />))}
    </div>
    <p class="me-note">התמונות מפרויקטים שבוצעו במסגרת Two studio.</p>
  </section>

  <!-- OFFER / WHAT'S INCLUDED -->
  <section class="me-included">
    <div class="wrap">
      <h2 class="me-h">אז מה בעצם אני מציעה?</h2>
      <p class="me-sub"><span class="me-mie">Make it easy</span> – שתי פגישות שיגרמו לך להתאהב בבית שלך, בקלות!</p>
      <p class="me-sub me-q2">"רק שתי פגישות?" – כן. בואי תראי מה הן כוללות:</p>
      <div class="me-grid">
        {meetings.map((s, i) => (
          <div class="me-card reveal">
            {s.img && <div class="me-card__img"><img src={s.img} alt={s.t} loading="lazy" /></div>}
            <div class="me-card__b">
              <span class="me-num">{String(i + 1).padStart(2, '0')}</span>
              <h4>{s.t}</h4>
              <p>{s.p}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="me-divider reveal">
        <h3>חשבת שסיימנו? אז לא :)</h3>
        <p>גם אחרי יום הרכישות – אני עדיין איתך.</p>
      </div>

      <div class="me-grid me-grid--3">
        {after.map((s, i) => (
          <div class="me-card reveal">
            {s.img && <div class={`me-card__img${s.fit === 'contain' ? ' me-card__img--contain' : ''}`}><img src={s.img} alt={s.t} loading="lazy" /></div>}
            {s.icon === 'gift' && <div class="me-card__img me-card__img--icon" set:html={`<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='9' width='18' height='12' rx='1'/><path d='M3 13h18M12 9v12'/><path d='M12 9S9 3 6.5 4.5 9 9 12 9zM12 9s3-6 5.5-4.5S15 9 12 9z'/></svg>`}></div>}
            <div class="me-card__b">
              <span class="me-num">{String(i + 5).padStart(2, '0')}</span>
              <h4>{s.t}</h4>
              <p>{s.p}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICE -->
  <section class="me-price">
    <div class="wrap reveal">
      <span class="me-eyebrow">המחיר ל־Make it easy הוא</span>
      <div class="me-price__num">4,200 <span>₪</span></div>
      <p>אני יכולה להבטיח לך שזו תהיה ההוצאה הכי משתלמת שתעשי!</p>
      <p class="me-price__note">אני מקבלת רק שני לקוחות בחודש למסלול הזה. אז אם חשוב לך להתחיל כבר בתהליך, מלאי כאן את הפרטים שלך ואחזור אלייך לשיחת התאמה. (שעות הפעילות של הסטודיו: ימים א'–ה', 9:00–18:00.)</p>
      <a href="#lead" class="me-btn me-btn--light">אני רוצה להשאיר פרטים</a>
    </div>
  </section>

  <!-- LEAD FORM -->
  <section class="me-lead" id="lead">
    <div class="wrap">
      <h2 class="me-h">מלאי כאן את הפרטים ואחזור אלייך לשיחת התאמה</h2>
      <form class="me-form" id="meForm" action={FORM_ENDPOINT} method="POST" target="me_sink">
        <div class="me-row">
          <label>שם פרטי<input type="text" name="entry.531547197" required autocomplete="given-name" /></label>
          <label>שם משפחה<input type="text" name="entry.1182931697" required autocomplete="family-name" /></label>
        </div>
        <div class="me-row">
          <label>מייל<input type="email" name="entry.1907419897" required autocomplete="email" dir="ltr" /></label>
          <label>נייד<input type="tel" name="entry.732060466" required autocomplete="tel" dir="ltr" /></label>
        </div>
        <button type="submit" class="me-btn me-form__btn">אני כבר רוצה להתאהב בבית שלי!</button>
        <p class="me-form__msg" id="meMsg" hidden></p>
      </form>
      <iframe name="me_sink" title="submit" style="display:none"></iframe>
    </div>
  </section>

  <!-- FAQ -->
  <section class="me-sec wrap">
    <h2 class="me-h">למי מתאים המסלול, ועוד שאלות שאולי עלו לך</h2>
    <div class="me-faq">
      {faqs.map((f) => (
        <details class="me-q">
          <summary>{f.q}<span class="me-q__mark" aria-hidden="true">+</span></summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
    <div class="me-faq__cta"><a href="#lead" class="me-btn">מתאים לי – אשאיר פרטים</a></div>
  </section>

  <!-- ABOUT -->
  <section class="me-about">
    <div class="wrap me-about__in">
      <div class="me-about__img reveal"><img src={img.profile} alt="שרון שגיא" loading="lazy" /></div>
      <div class="me-about__txt reveal">
        <span class="me-eyebrow">אם את עדיין לא מכירה אותי – זה הזמן</span>
        <h2 class="me-h">אני שרון שגיא</h2>
        <p>מעצבת פנים המתמחה בתכנון וליווי שיפוצים ובתים בבנייה.</p>
        <p>עוד כילדה נמשכתי לעולם הזה – הייתי משנה שוב ושוב את סידור ועיצוב החדר שלי.</p>
        <p>לפני שהגעתי לעיצוב פנים עסקתי בכלל בייעוץ גנטי – תחום שלימד אותי להקשיב, לחשוב לעומק, לראות את התמונה המלאה ולשים לב לכל פרט קטן. היום אני מביאה בדיוק את אותה גישה גם לתכנון בתים.</p>
        <p>אני מאמינה שבית טוב מתחיל הרבה לפני בחירת צבעים וחומרים – הוא מתחיל בתכנון מדויק, בהבנת הצרכים וההרגלים של המשפחה, וביצירת פתרונות חכמים שמאפשרים לבית לעבוד באמת ביום־יום. אני אוהבת את החיבור בין חשיבה תכנונית ופתרון בעיות לבין החלק היצירתי של בחירת חומרים, צבעים והלבשת הבית – וכך נוצרים בתים שהם גם פונקציונליים ונוחים לחיים, וגם מעוצבים ומלאי אופי.</p>
        <p class="me-lead-line">אז בואי נצא לדרך יחד 💜</p>
      </div>
    </div>
  </section>

  <div class="me-tosite"><a href="/">‹ לאתר של שרון שגיא</a></div>

  <style>
    .me-btn{display:inline-block;background:var(--accent);color:#fff;border:1px solid var(--accent);padding:15px 40px;border-radius:50px;font-size:1.02rem;letter-spacing:.02em;cursor:pointer;transition:.3s}
    @media (hover:hover){.me-btn:hover{background:var(--accent-deep);border-color:var(--accent-deep)}}
    .me-btn--light{background:#fff;color:var(--accent-deep);border-color:#fff}
    @media (hover:hover){.me-btn--light:hover{background:var(--bg-2);color:var(--accent-deep)}}
    .me-eyebrow{font-family:var(--lat);font-style:italic;color:var(--accent-deep);font-size:1.1rem;letter-spacing:.04em}
    .me-h{font-family:var(--serif);font-weight:300;font-size:clamp(1.9rem,4.5vw,3rem);line-height:1.12;color:var(--ink);text-align:center}
    .me-sub{text-align:center;color:var(--ink-soft);max-width:62ch;margin:14px auto 0;font-size:1.1rem;line-height:1.7}
    .me-note{text-align:center;color:var(--ink-soft);opacity:.75;font-size:.85rem;margin-top:22px}
    .me-muted{color:var(--ink-soft)}
    .me-sec{padding:8vh 0}
    /* keep the logo, hide only the site menu links + hamburger */
    :global(#navLinks),:global(#navToggle){display:none !important}
    .me-mie{font-family:var(--lat);font-style:italic;color:var(--accent);font-size:1.3em;font-weight:500}
    .me-q2{margin-top:8px}
    .me-note--top{margin-top:8px;margin-bottom:6px}
    .me-tosite{text-align:center;background:var(--band);padding:7vh var(--pad) 3vh}
    .me-tosite a{color:var(--accent-deep);font-size:1.02rem;letter-spacing:.02em}

    .me-hero{background:var(--band);padding:6vh var(--pad) 12vh;text-align:center}
    .me-hero__in{max-width:900px;margin:0 auto}
    .me-hero h1{font-family:var(--serif);font-weight:300;font-size:clamp(2.1rem,5.4vw,3.7rem);line-height:1.14;margin:16px 0 0;color:var(--ink)}
