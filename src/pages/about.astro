---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
const a = site.about;
const values = a.values || [];
const steps = a.steps || [];
const hasProcess = steps.length > 0 || (a.processTitle && a.processTitle.trim()) || (a.processEyebrow && a.processEyebrow.trim());
const nl = (t) => t.replace(/\n/g, '<br/>');
---
<Base active="about" solidNav={true} title="אודות · שרון שגיא">
  <header class="page-head reveal">
    <h1 set:html={nl(a.title)}></h1>
    <p>{a.lead}</p>
  </header>

  <section class="about wrap">
    <div class="about__img reveal"><img src="/assets/profile.jpg" alt="שרון שגיא" /></div>
    <div class="about__txt reveal">
      {(a.paragraphs || []).map((t) => (<p>{t}</p>))}
      <div class="values">
        {values.map((v) => (<div><div class="v-n">{v.n}</div><div class="v-t">{v.t}</div></div>))}
      </div>
    </div>
  </section>

  {hasProcess && (
  <section class="process">
    <div class="wrap">
      <div class="proc-head reveal"><span class="eyebrow">{a.processEyebrow}</span><h2 class="h-sec">{a.processTitle}</h2></div>
      <div class="proc-grid">
        {steps.map((s) => (
          <div class="proc-step reveal"><div class="proc-n">{s.n}</div><h4>{s.h}</h4><p>{s.p}</p></div>
        ))}
      </div>
    </div>
  </section>
  )}

  <section class="endcta">
    <div class="wrap reveal">
      <h2 class="h-sec">{a.endTitle}</h2>
      <a href="/contact" class="btn btn-solid">{a.endCta}</a>
    </div>
  </section>
</Base>

<style>
  .about{display:grid;grid-template-columns:.85fr 1.15fr;gap:clamp(34px,5vw,76px);align-items:start;padding:4vh 0 12vh}
  .about__img{aspect-ratio:4/5;overflow:hidden;background:var(--bg-2);box-shadow:0 24px 60px rgba(38,32,25,.14);position:sticky;top:96px}
  .about__img img{width:100%;height:100%;object-fit:cover}
  .about__txt p{color:var(--ink-soft);margin-bottom:1.3em;font-size:1.08rem;line-height:1.95}
  .about__txt b{color:var(--ink);font-weight:500}
  .values{display:flex;gap:40px;margin-top:30px;flex-wrap:wrap}
  .values div{flex:1;min-width:120px}
  .values .v-n{font-family:var(--lat);font-style:italic;color:var(--accent);font-size:1.1rem}
  .values .v-t{font-family:var(--serif);font-size:1.35rem;margin-top:4px}
  .process{background:var(--bg);padding:12vh 0}
  .proc-head{margin-bottom:54px}
  .proc-head .eyebrow{display:block;margin-bottom:12px}
  .proc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}
  .proc-n{font-family:var(--lat);font-style:italic;font-size:2.6rem;color:var(--accent-deep);opacity:.5;line-height:1}
  .proc-step h4{font-family:var(--serif);font-size:1.4rem;margin:.4em 0;color:var(--ink)}
  .proc-step p{font-size:.97rem;color:#5b4a3c;line-height:1.8}
  .endcta{text-align:center;padding:13vh 0}
  .endcta h2{margin-bottom:1em}
  @media(max-width:880px){.about{grid-template-columns:1fr;gap:30px}.about__img{position:static}.proc-grid{grid-template-columns:repeat(2,1fr)}}
</style>
