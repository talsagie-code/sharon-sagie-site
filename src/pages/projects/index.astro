---
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/projects.js';
---
<Base active="projects" solidNav={true} title="פרויקטים · שרון שגיא">
  <header class="page-head reveal">
    <span class="eyebrow">עבודות</span>
    <h1>פרויקטים</h1>
    <p>בתים פרטיים, דירות וחללים מסחריים — כל אחד עם סיפור, אופי וצרכים משלו.</p>
  </header>

  <section class="wrap plist">
    {projects.map((p) => (
      <a class="pcard reveal" href={`/projects/${p.slug}`}>
        <div class="pcard__media">
          <img src={p.cover} alt={p.title} loading="lazy" />
          <div class="pcard__hover"><img class="pcard__mark" src="/assets/mark.png" alt="" /><span class="pcard__cap">{p.title}</span></div>
        </div>
        <div class="pcard__meta"><h3>{p.title}</h3></div>
      </a>
    ))}
  </section>
</Base>

<style>
  .plist{display:grid;grid-template-columns:1fr 1fr;gap:clamp(18px,2.4vw,34px);padding:4vh 0 14vh}
  .pcard{display:block}
  .pcard__media{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--bg-2)}
  .pcard__media>img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s cubic-bezier(.2,.7,.2,1)}
  .pcard:hover .pcard__media>img{transform:scale(1.05)}
  .pcard__hover{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;background:rgba(247,244,239,.62);opacity:0;transition:opacity .5s}
  .pcard:hover .pcard__hover{opacity:1}
  .pcard__mark{width:58px;height:auto;transform:translateY(6px);transition:transform .6s}
  .pcard:hover .pcard__mark{transform:translateY(0)}
  .pcard__cap{font-family:var(--serif);font-size:1.5rem;color:var(--ink);transform:translateY(12px);transition:transform .6s .05s}
  .pcard:hover .pcard__cap{transform:translateY(0)}
  .pcard__meta{padding:16px 2px 0}
  .pcard__meta h3{font-family:var(--serif);font-weight:400;font-size:clamp(1.3rem,2vw,1.7rem)}
  @media(max-width:780px){.plist{grid-template-columns:1fr}}
</style>
