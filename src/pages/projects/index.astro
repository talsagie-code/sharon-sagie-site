---
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/projects.js';
---
<Base active="projects" solidNav={true} title="פרויקטים · שרון שגיא">
  <header class="page-head reveal">
    <span class="eyebrow">עבודות</span>
    <h1>פרויקטים</h1>
    <p>בתים פרטיים, דירות וחללים מסחריים — כל אחד עם סיפור, אופי וצרכים משלו.</p>
  </header>

  <section class="wrap plist">
    {projects.map((p) => (
      <a class="pcard reveal" href={`/projects/${p.slug}`}>
        <div class="pcard__media">
          <img src={p.cover} alt={p.title} loading="lazy" />
          <div class="pcard__overlay">
            <span class="pcard__cap">{p.title}</span>
            {p.comingSoon && <span class="pcard__soon">coming soon…</span>}
          </div>
        </div>
      </a>
    ))}
  </section>
</Base>

<style>
  .plist{display:grid;grid-template-columns:1fr 1fr;gap:clamp(18px,2.4vw,34px);padding:4vh 0 14vh}
  .pcard{display:block}
  .pcard__media{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--bg-2);border-radius:3px}
  .pcard__media>img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s cubic-bezier(.2,.7,.2,1)}
  .pcard:hover .pcard__media>img{transform:scale(1.05)}
  .pcard__overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:flex-start;justify-content:flex-end;gap:3px;padding:22px 24px;background:linear-gradient(to top,rgba(26,20,15,.62),rgba(26,20,15,.12) 42%,rgba(26,20,15,0) 70%)}
  .pcard__cap{font-family:var(--serif);font-weight:500;font-size:clamp(1.3rem,2vw,1.7rem);color:#fff;text-shadow:0 1px 14px rgba(0,0,0,.35)}
  .pcard__soon{font-size:.82rem;letter-spacing:.14em;color:rgba(255,255,255,.92);text-shadow:0 1px 10px rgba(0,0,0,.4)}
  @media(max-width:780px){.plist{grid-template-columns:1fr}}
</style>
