---
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/projects.js';
---
<Base active="projects" solidNav={true} title="פרויקטים · שרון שגיא">
  <header class="page-head reveal">
    <h1>פרויקטים</h1>
    <p>הפרויקטים המוצגים בוצעו בתקופת ״two studio״, בשיתוף עם המעצבת קרן לוטם.</p>
  </header>

  <section class="wrap plist">
    {projects.map((p) => (
      <a class="pcard reveal" href={`/projects/${p.slug}`}>
        <div class="pcard__media">
          <img src={p.cover} alt={p.title} loading="lazy" />
          <div class="pcard__overlay">
            <img class="pcard__mark" src="/assets/mark.png" alt="" />
            <span class="pcard__cap">{p.title}</span>
            {p.comingSoon && <span class="pcard__soon">coming soon…</span>}
          </div>
        </div>
      </a>
    ))}
  </section>
</Base>

<style>
  .plist{display:grid;grid-template-columns:1fr 1fr;gap:clamp(18px,2.4vw,34px);padding:4vh 0 14vh}
  .pcard{display:block}
  .pcard__media{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--bg-2);border-radius:3px}
  .pcard__media>img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s cubic-bezier(.2,.7,.2,1)}.pcard:hover .pcard__media>img{transform:scale(1.05)}
  .pcard__overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;padding:20px;background:rgba(247,244,239,.72);opacity:0;transition:opacity .45s ease}
  .pcard.is-open .pcard__overlay{opacity:1}
  .pcard__mark{width:56px;height:auto;transform:translateY(8px);transition:transform .6s}
  .pcard__cap{font-family:var(--serif);font-weight:500;font-size:clamp(1.3rem,2vw,1.7rem);color:var(--ink);transform:translateY(12px);transition:transform .6s .05s}
  .pcard__soon{font-size:.82rem;letter-spacing:.14em;direction:ltr;color:var(--accent-deep);transform:translateY(12px);transition:transform .6s .08s}
  .pcard.is-open .pcard__mark{transform:translateY(0)}
  .pcard.is-open .pcard__cap{transform:translateY(0)}
  .pcard.is-open .pcard__soon{transform:translateY(0)}
  @media(max-width:780px){.plist{grid-template-columns:1fr}}
</style>
