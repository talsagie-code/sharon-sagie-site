---
import Base from '../layouts/Base.astro';
import { projects, heroImages, testimonials } from '../data/projects.js';
import site from '../data/site.json';
const featured = projects;
const nl = (t) => t.replace(/\n/g, '<br/>');
---
<Base active="home">
  <!-- HERO -->
  <header class="hero">
    <div class="hero__imgs">
      {(heroImages || []).map((src, i) => (
        <div class={`hero__img${i === 0 ? ' on' : ''}`} style={`background-image:url('${src}')`}></div>
      ))}
    </div>
    <div class="hero__veil"></div>
    <div class="hero__inner">
      <span class="hero__eyebrow">{site.hero.eyebrow}</span>
      <h1 set:html={nl(site.hero.title)}></h1>
      <a href="/projects" class="hero__cta">{site.hero.cta}</a>
    </div>
    <div class="hero__scroll">scroll</div>
  </header>

  <!-- ABOUT TEASER -->
  <section class="about-teaser wrap">
    <div class="about-teaser__img reveal"><img src="/assets/profile.jpg" alt="שרון שגיא" /></div>
    <div class="about-teaser__txt reveal">
      <span class="eyebrow">{site.homeAbout.eyebrow}</span>
      <h2 class="h-sec" set:html={nl(site.homeAbout.title)}></h2>
      <p class="lead">{site.homeAbout.lead}</p>
      <a href="/about" class="btn btn-ghost">{site.homeAbout.cta}</a>
    </div>
  </section>

  <!-- PHILOSOPHY QUOTE -->
  <section class="quote-band">
    <div class="qb reveal">
      <span class="qb__mark" aria-hidden="true">״</span>
      <blockquote class="qb__quote">{site.philosophyQuote}</blockquote>
      <cite class="qb__author">{site.philosophyAuthor}</cite>
      <p class="qb__note">{site.philosophyNote}</p>
    </div>
  </section>

  <!-- PROJECTS PREVIEW -->
  <section class="proj wrap">
    <div class="proj__head reveal">
      <h2 class="h-sec">פרויקטים נבחרים</h2>
      <a href="/projects" class="proj__all">לכל הפרויקטים →</a>
    </div>
    <div class="proj__grid">
      {(featured || []).map((p) => (
        <a class="proj__card reveal" href={`/projects/${p.slug}`}>
          <div class="proj__media">
            <img src={p.cover} alt={p.title} loading="lazy" />
            <div class="proj__overlay">
              <img class="proj__mark" src="/assets/mark.png" alt="" />
              <span class="proj__cap">{p.title}</span>
              {p.comingSoon && <span class="proj__soon">coming soon…</span>}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="svc-prev">
    <div class="wrap svc-prev__in reveal">
      <span class="eyebrow">{site.homeServices.eyebrow}</span>
      <h2 class="h-sec">{site.homeServices.title}</h2>
      <p class="lead">{site.homeServices.lead}</p>
      <a href="/services" class="btn btn-solid">{site.homeServices.cta}</a>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="tst wrap">
    <div class="tst__mark">״</div>
    <div class="tst__track" id="tstTrack">
      {(testimonials || []).slice(0,3).map((t, i) => (
        <figure class={`tst__q${i === 0 ? ' on' : ''}`}>
          <blockquote>{t.quote}</blockquote>
          <figcaption>{t.who} · {t.where}</figcaption>
        </figure>
      ))}
    </div>
    <div class="tst__dots" id="tstDots"></div>
  </section>

  <!-- CONTACT CTA -->
  <section class="cta">
    <div class="wrap cta__in reveal">
      <span class="eyebrow">{site.homeContact.eyebrow}</span>
      <h2 class="h-sec">{site.homeContact.title}</h2>
      <p class="lead">{site.homeContact.lead}</p>
      <a href="https://wa.me/9720523724032" class="btn btn-solid">{site.homeContact.cta}</a>
    </div>
  </section>
</Base>

<style>
  .hero{position:relative;height:100vh;min-height:620px;overflow:hidden;display:flex;align-items:flex-end}
  .hero__imgs{position:absolute;inset:0}
  .hero__img{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transform:scale(1.06);transition:opacity 1.6s ease,transform 7s ease}
  .hero__img.on{opacity:1;transform:scale(1)}
  .hero__veil{position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,16,12,.4) 0%,rgba(20,16,12,.05) 35%,rgba(20,16,12,.66) 100%)}
  .hero__inner{position:relative;z-index:2;color:#fff;max-width:var(--maxw);width:100%;margin:0 auto;padding:0 var(--pad) 11vh}
  .hero__eyebrow{font-family:var(--lat);font-style:italic;font-size:1.45rem;letter-spacing:.05em}
  .hero h1{font-family:var(--serif);font-weight:300;font-size:clamp(2.5rem,6.8vw,5.8rem);line-height:1.04;letter-spacing:-.01em;margin:.15em 0 .55em}
  .hero__cta{display:inline-block;border:1px solid rgba(255,255,255,.7);color:#fff;padding:13px 30px;border-radius:50px;font-size:.95rem;letter-spacing:.04em;transition:.4s}
  .hero__cta:hover{background:#fff;color:var(--ink)}
  .hero__scroll{position:absolute;bottom:26px;inset-inline-start:50%;transform:translateX(-50%);z-index:2;color:#fff;font-size:.72rem;letter-spacing:.3em;writing-mode:vertical-rl;opacity:.85}
  .hero__scroll::after{content:"";display:block;width:1px;height:46px;background:#fff;margin:10px auto 0;animation:cue 1.8s ease-in-out infinite}
  @keyframes cue{0%,100%{transform:scaleY(.4);opacity:.4;transform-origin:top}50%{transform:scaleY(1);opacity:1;transform-origin:top}}

  .about-teaser{display:grid;grid-template-columns:.9fr 1.1fr;gap:clamp(34px,5vw,76px);align-items:center;padding:10vh 0}
  .about-teaser__img{aspect-ratio:5/5.4;overflow:hidden;background:var(--bg-2);box-shadow:0 24px 60px rgba(38,32,25,.14)}
  .about-teaser__img img{width:100%;height:100%;object-fit:cover}
  .about-teaser__txt .eyebrow{display:block;margin-bottom:14px}
  .about-teaser__txt h2{margin-bottom:.5em}
  .about-teaser__txt .lead{margin-bottom:2em;max-width:52ch}

  .quote-band{background:var(--band);padding:11vh var(--pad);text-align:center}
  .qb{max-width:900px;margin:0 auto;display:flex;flex-direction:column;align-items:center}
  .qb__mark{font-family:var(--serif);font-size:4.2rem;line-height:.5;color:var(--accent);opacity:.55;margin-bottom:14px}
  .qb__quote{font-family:var(--serif);font-weight:300;font-style:italic;font-size:clamp(1.35rem,2.9vw,2.2rem);line-height:1.5;color:var(--ink);direction:ltr;max-width:780px;margin:0}
  .qb__author{display:block;margin-top:16px;font-family:var(--lat);font-style:normal;font-size:1.02rem;letter-spacing:.1em;color:var(--accent-deep);direction:ltr}
  .qb__note{margin-top:42px;font-family:var(--serif);font-weight:300;font-size:clamp(1.05rem,1.7vw,1.3rem);line-height:1.7;color:var(--ink-soft);max-width:620px}

  .proj{padding:10vh 0}
  .proj__head{display:flex;align-items:flex-end;justify-content:space-between;gap:24px;border-bottom:1px solid var(--line);padding-bottom:24px;margin-bottom:46px}
  .proj__all{color:var(--accent);font-size:1rem;white-space:nowrap}
  .proj__grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(18px,2.4vw,34px)}
  .proj__card{display:block}
  .proj__media{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--bg-2);border-radius:3px}
  .proj__media>img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s cubic-bezier(.2,.7,.2,1)}
  .proj__card:hover .proj__media>img{transform:scale(1.05)}
  .proj__overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;padding:20px;background:rgba(247,244,239,.72);opacity:0;transition:opacity .45s ease}
  .proj__card.is-open .proj__overlay{opacity:1}
  .proj__mark{width:54px;height:auto;transform:translateY(8px);transition:transform .6s}
  .proj__cap{font-family:var(--serif);font-weight:500;font-size:clamp(1.3rem,2vw,1.7rem);color:var(--ink);transform:translateY(12px);transition:transform .6s .05s}
  .proj__soon{font-size:.82rem;letter-spacing:.14em;direction:ltr;color:var(--accent-deep);transform:translateY(12px);transition:transform .6s .08s}
  .proj__card.is-open .proj__mark{transform:translateY(0)}
  .proj__card.is-open .proj__cap{transform:translateY(0)}
  .proj__card.is-open .proj__soon{transform:translateY(0)}

  .svc-prev{background:var(--band);color:var(--ink)}
  .svc-prev__in{padding:11vh 0;text-align:center;max-width:880px}
  .svc-prev__in .eyebrow{display:block;margin-bottom:14px;color:var(--accent-deep)}
  .svc-prev__in h2{color:var(--ink);margin-bottom:.5em}
  .svc-prev__in .lead{color:var(--ink-soft);margin:0 auto 2em;max-width:56ch}

  .tst{padding:11vh 0;text-align:center;max-width:980px}
  .tst__mark{font-family:var(--serif);font-size:5rem;line-height:.4;color:var(--accent);opacity:.45;height:46px}
  .tst__track{position:relative;min-height:240px}
  .tst__q{position:absolute;inset:0;opacity:0;transform:translateY(16px);transition:opacity .9s,transform .9s;display:flex;flex-direction:column;justify-content:center}
  .tst__q.on{opacity:1;transform:none;position:relative}
  .tst__q blockquote{font-family:var(--serif);font-weight:300;font-size:clamp(1.3rem,2.6vw,2rem);line-height:1.6;margin-bottom:26px}
  .tst__q figcaption{font-size:.92rem;letter-spacing:.1em;color:var(--accent-deep);font-weight:500}
  .tst__dots{display:flex;gap:9px;justify-content:center;margin-top:38px}
  .tst__dots button{width:8px;height:8px;border-radius:50%;border:none;background:var(--line);cursor:pointer;padding:0;transition:.4s}
  .tst__dots button.on{background:var(--accent);width:24px;border-radius:5px}

  .cta{background:var(--band)}
  .cta__in{padding:11vh 0;text-align:center;max-width:760px}
  .cta__in .eyebrow{display:block;margin-bottom:14px}
  .cta__in h2{margin-bottom:.4em}
  .cta__in .lead{margin-bottom:2em}

  @media(max-width:880px){
    .about-teaser{grid-template-columns:1fr;gap:30px;padding:11vh 0}
    .proj__grid{grid-template-columns:1fr}
    .proj__head{flex-wrap:wrap}
  }
</style>

<script>
  // hero rotator
  const imgs = [...document.querySelectorAll('.hero__img')];
  let hi = 0;
  if (imgs.length > 1) setInterval(() => { imgs[hi].classList.remove('on'); hi = (hi + 1) % imgs.length; imgs[hi].classList.add('on'); }, 4500);
  // testimonials
  const qs = [...document.querySelectorAll('.tst__q')];
  const dotsWrap = document.getElementById('tstDots');
  let ti = 0;
  qs.forEach((_, i) => { const b = document.createElement('button'); if (!i) b.classList.add('on'); b.addEventListener('click', () => go(i)); dotsWrap.appendChild(b); });
  function go(i){ qs[ti].classList.remove('on'); dotsWrap.children[ti].classList.remove('on'); ti = i; qs[ti].classList.add('on'); dotsWrap.children[ti].classList.add('on'); }
  if (qs.length > 1) setInterval(() => go((ti + 1) % qs.length), 5500);
</script>
