---
import Base from '../layouts/Base.astro';
import { projects, heroImages, testimonials } from '../data/projects.js';
import site from '../data/site.json';
const featured = projects;
const nl = (t) => t.replace(/\n/g, '<br/>');
// Philosophy quote — hardcoded source of truth so a CMS save can never wipe it.
const philosophyQuote = site.philosophyQuote || "Design is not just what it looks like and feels like. Design is how it works.";
const philosophyAuthor = site.philosophyAuthor || "Steve Jobs";
const philosophyNote = site.philosophyNote || "זו הדרך שבה אני ניגשת לתכנון - קודם חושבת על החיים בבית, ורק אחר כך איך הוא ייראה.";
---
<Base active="home">
  <!-- HERO -->
  <header class="hero">
    <div class="hero__imgs">
      {(heroImages || []).map((src, i) => (
        <div class={`hero__img${i === 0 ? ' on' : ''}`} style={i === 0 ? `background-image:url('${src}')` : ''} data-bg={i === 0 ? null : src}></div>
      ))}
    </div>
    <div class="hero__veil"></div>
    <div class="hero__inner">
      <span class="hero__eyebrow">{site.hero.eyebrow}</span>
      <h1 set:html={nl(site.hero.title)}></h1>
      <a href="/projects" class="hero__cta">{site.hero.cta}</a>
    </div>
    <div class="hero__scroll">scroll</div>
  </header>

  <!-- ABOUT TEASER -->
  <section class="about-teaser wrap">
    <div class="about-teaser__img reveal"><img src="/assets/home-portrait.webp" alt="שרון שגיא" /></div>
    <div class="about-teaser__txt reveal">
      <span class="eyebrow">{site.homeAbout.eyebrow}</span>
      <h2 class="h-sec" set:html={nl(site.homeAbout.title)}></h2>
      <p class="lead">{site.homeAbout.lead}</p>
      <a href="/about" class="btn btn-solid">{site.homeAbout.cta}</a>
    </div>
  </section>

  <!-- PHILOSOPHY QUOTE -->
  <section class="quote-band">
    <div class="qb reveal">
      <span class="qb__mark" aria-hidden="true">״</span>
      <blockquote class="qb__quote">{philosophyQuote}</blockquote>
      <cite class="qb__author">{philosophyAuthor}</cite>
      <p class="qb__note">{philosophyNote}</p>
    </div>
  </section>

  <!-- PROJECTS PREVIEW -->
  <section class="proj wrap">
    <div class="proj__head reveal">
      <h2 class="h-sec">פרויקטים נבחרים</h2>
      <a href="/projects" class="proj__all">לכל הפרויקטים →</a>
    </div>
    <div class="proj__grid">
      {(featured || []).map((p) => (
        <a class="proj__card reveal" href={`/projects/${p.slug}`}>
          <div class="proj__media">
            <img src={p.cover} alt={p.title} loading="lazy" />
            <div class="proj__overlay">
              <img class="proj__mark" src="/assets/mark.png" alt="" />
              <span class="proj__cap">{p.title}</span>
              {p.comingSoon && <span class="proj__soon">coming soon…</span>}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="svc-prev">
    <div class="wrap svc-prev__in reveal">
      <span class="eyebrow">{site.homeServices.eyebrow}</span>
      <h2 class="h-sec">{site.homeServices.title}</h2>
      <p class="lead">{site.homeServices.lead}</p>
      <a href="/services" class="btn btn-solid">{site.homeServices.cta}</a>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="tst wrap">
    <div class="tst__mark">״</div>
    <div class="tst__viewport">
      <button class="tst__arrow tst__prev" id="tstPrev" type="button" aria-label="הקודמת"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg></button>
      <div class="tst__track" id="tstTrack">
        {(testimonials || []).slice(0,3).map((t) => (
          <figure class="tst__q">
            <blockquote>{t.quote}</blockquote>
            <figcaption>{t.who} · {t.where}</figcaption>
            <button class="tst__more" type="button">קרא עוד</button>
          </figure>
        ))}
      </div>
      <button class="tst__arrow tst__next" id="tstNext" type="button" aria-label="הבאה"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"></polyline></svg></button>
    </div>
    <div class="tst__dots" id="tstDots"></div>
    <a href="/testimonials" class="tst__all">לכל ההמלצות ←</a>
    <p class="tst__src">המלצות של לקוחות מתקופת העבודה ב two studio.</p>
  </section>

  <!-- CONTACT CTA -->
  <section class="cta">
    <div class="wrap cta__in reveal">
      <span class="eyebrow">{site.homeContact.eyebrow}</span>
      <a href="https://wa.me/9720523724032" class="btn btn-solid cta__btn">{site.homeContact.cta}</a>
    </div>
  </section>
</Base>

<style>
  .hero{position:relative;height:100vh;min-height:620px;overflow:hidden;display:flex;align-items:flex-end}
  .hero__imgs{position:absolute;inset:0}
  .hero__img{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transform:scale(1.06);transition:opacity 1.6s ease,transform 7s ease}
  .hero__img.on{opacity:1;transform:scale(1)}
  .hero__veil{position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,16,12,.4) 0%,rgba(20,16,12,.05) 35%,rgba(20,16,12,.66) 100%)}
  .hero__inner{position:relative;z-index:2;color:#fff;max-width:var(--maxw);width:100%;margin:0 auto;padding:0 var(--pad) 11vh}
  .hero__eyebrow{font-family:var(--lat);font-style:italic;font-size:1.45rem;letter-spacing:.05em}
  .hero h1{font-family:var(--serif);font-weight:300;font-size:clamp(2.5rem,6.8vw,5.8rem);line-height:1.04;letter-spacing:-.01em;margin:.15em 0 .55em}
  .hero__cta{display:inline-block;border:1px solid rgba(255,255,255,.7);color:#fff;padding:13px 30px;border-radius:50px;font-size:.95rem;letter-spacing:.04em;transition:.4s}@media (hover:hover){.hero__cta:hover{background:#fff;color:var(--ink)}}
  .hero__scroll{position:absolute;bottom:26px;inset-inline-start:50%;transform:translateX(-50%);z-index:2;color:#fff;font-size:.72rem;letter-spacing:.3em;writing-mode:vertical-rl;opacity:.85}
  .hero__scroll::after{content:"";display:block;width:1px;height:46px;background:#fff;margin:10px auto 0;animation:cue 1.8s ease-in-out infinite}
  @keyframes cue{0%,100%{transform:scaleY(.4);opacity:.4;transform-origin:top}50%{transform:scaleY(1);opacity:1;transform-origin:top}}

  .about-teaser{display:grid;grid-template-columns:.9fr 1.1fr;gap:clamp(34px,5vw,76px);align-items:center;padding:10vh 0}
  .about-teaser__img{aspect-ratio:5/5.4;overflow:hidden;background:var(--bg-2);box-shadow:0 24px 60px rgba(38,32,25,.14)}
  .about-teaser__img img{width:100%;height:100%;object-fit:cover}
  .about-teaser__txt .eyebrow{display:block;margin-bottom:14px}
  .about-teaser__txt h2{margin-bottom:.5em}
  .about-teaser__txt .lead{margin-bottom:2em;max-width:52ch}

  .quote-band{background:var(--band);padding:11vh var(--pad);text-align:center}
  .qb{max-width:900px;margin:0 auto;display:flex;flex-direction:column;align-items:center}
  .qb__mark{font-family:var(--serif);font-size:4.2rem;line-height:.5;color:var(--accent);opacity:.55;margin-bottom:14px}
  .qb__quote{font-family:var(--serif);font-weight:300;font-style:italic;font-size:clamp(1.35rem,2.9vw,2.2rem);line-height:1.5;color:var(--ink);direction:ltr;max-width:780px;margin:0}
  .qb__author{display:block;margin-top:16px;font-family:var(--lat);font-style:normal;font-size:1.02rem;letter-spacing:.1em;color:var(--accent-deep);direction:ltr}
  .qb__note{margin-top:42px;font-family:var(--serif);font-weight:300;font-size:clamp(1.2rem,2vw,1.55rem);line-height:1.7;color:var(--ink-soft);max-width:660px}

  .proj{padding:10vh 0}
  .proj__head{display:flex;align-items:flex-end;justify-content:space-between;gap:24px;border-bottom:1px solid var(--line);padding-bottom:24px;margin-bottom:46px}
  .proj__all{color:var(--accent);font-size:1rem;white-space:nowrap}
  .proj__grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(18px,2.4vw,34px)}
  .proj__card{display:block}
  .proj__media{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--bg-2);border-radius:3px}
  .proj__media>img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s cubic-bezier(.2,.7,.2,1)}.proj__card:hover .proj__media>img{transform:scale(1.05)}
  .proj__overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;padding:20px;background:rgba(247,244,239,.72);opacity:0;transition:opacity .45s ease}
  .proj__card.is-open .proj__overlay{opacity:1}
  .proj__mark{width:54px;height:auto;transform:translateY(8px);transition:transform .6s}
  .proj__cap{font-family:var(--serif);font-weight:500;font-size:clamp(1.3rem,2vw,1.7rem);color:var(--ink);transform:translateY(12px);transition:transform .6s .05s}
  .proj__soon{font-size:.82rem;letter-spacing:.14em;direction:ltr;color:var(--accent-deep);transform:translateY(12px);transition:transform .6s .08s}
  .proj__card.is-open .proj__mark{transform:translateY(0)}
  .proj__card.is-open .proj__cap{transform:translateY(0)}
  .proj__card.is-open .proj__soon{transform:translateY(0)}

  .svc-prev{background:var(--band);color:var(--ink)}
  .svc-prev__in{padding:11vh 0;text-align:center;max-width:880px}
  .svc-prev__in .eyebrow{display:block;margin-bottom:14px;color:var(--accent-deep)}
  .svc-prev__in h2{color:var(--ink);margin-bottom:.5em}
  .svc-prev__in .lead{color:var(--ink-soft);margin:0 auto 2em;max-width:56ch}

  .tst{padding:11vh 0;text-align:center;max-width:980px}
  .tst__mark{font-family:var(--serif);font-size:5rem;line-height:.4;color:var(--accent);opacity:.45;height:46px}
  .tst__viewport{position:relative;overflow:hidden;transition:height .5s cubic-bezier(.2,.7,.2,1)}
  .tst__track{display:flex;direction:ltr;transition:transform .55s cubic-bezier(.2,.7,.2,1);will-change:transform}
  .tst__track::-webkit-scrollbar{display:none}
  .tst__q{flex:0 0 100%;direction:rtl;align-self:flex-start;padding:0 clamp(56px,8vw,92px);box-sizing:border-box}
  .tst__q blockquote{font-family:var(--serif);font-weight:300;font-size:clamp(1.3rem,2.6vw,2rem);line-height:1.6;margin-bottom:18px;display:-webkit-box;-webkit-line-clamp:4;line-clamp:4;-webkit-box-orient:vertical;overflow:hidden}
  .tst__q.expanded blockquote{-webkit-line-clamp:unset;line-clamp:unset;-webkit-box-orient:initial;display:block;overflow:visible}
  .tst__more{margin-top:14px;background:none;border:none;font-family:inherit;color:var(--accent-deep);font-size:.92rem;letter-spacing:.04em;cursor:pointer;padding:0;text-decoration:underline;text-decoration-color:rgba(174,90,60,.4);text-underline-offset:4px;transition:.3s}@media (hover:hover){.tst__more:hover{text-decoration-color:var(--accent)}}
  .tst__more.hidden{display:none}
  .tst__q figcaption{font-size:.92rem;letter-spacing:.1em;color:var(--accent-deep);font-weight:500}
  .tst__arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:2;width:46px;height:46px;border-radius:50%;border:1px solid var(--line);background:rgba(255,255,255,.65);color:var(--accent-deep);display:grid;place-items:center;cursor:pointer;transition:.3s}@media (hover:hover){.tst__arrow:hover{border-color:var(--accent);background:#fff}}
  .tst__arrow svg{width:20px;height:20px}
  .tst__prev{inset-inline-start:-4px}
  .tst__next{inset-inline-end:-4px}
  .tst__dots{display:flex;gap:9px;justify-content:center;margin-top:34px}
  .tst__dots button{width:8px;height:8px;border-radius:50%;border:none;background:var(--line);cursor:pointer;padding:0;transition:.4s}
  .tst__dots button.on{background:var(--accent);width:24px;border-radius:5px}
  .tst__all{display:inline-block;margin-top:26px;color:var(--accent-deep);font-size:1rem;letter-spacing:.03em;transition:.3s}@media (hover:hover){.tst__all:hover{color:var(--accent)}}
  .tst__src{margin-top:20px;font-size:.8rem;color:var(--ink-soft);opacity:.8;letter-spacing:.02em}
  @media(max-width:680px){.tst__q{padding:0 46px}.tst__arrow{width:38px;height:38px}.tst__arrow svg{width:17px;height:17px}}

  .cta{background:var(--band)}
  .cta__in{padding:11vh 0;text-align:center;max-width:760px}
  .cta__in .eyebrow{display:block;margin-bottom:14px}
  .cta__in h2{margin-bottom:.4em}
  .cta__in .lead{margin-bottom:2em}

  @media(max-width:880px){
    .about-teaser{grid-template-columns:1fr;gap:30px;padding:11vh 0}
    .proj__grid{grid-template-columns:1fr}
    .proj__head{flex-wrap:wrap}
  }
</style>

<script>
  // hero rotator
  const imgs = [...document.querySelectorAll('.hero__img')];
  let hi = 0;
  const loadBg = (el) => { if (el && el.dataset.bg) { el.style.backgroundImage = `url('${el.dataset.bg}')`; el.removeAttribute('data-bg'); } };
    if (imgs.length > 1) setInterval(() => { imgs[hi].classList.remove('on'); hi = (hi + 1) % imgs.length; loadBg(imgs[hi]); imgs[hi].classList.add('on'); }, 4500);
  // testimonials slider: transform only (never scrolls the page) + touch swipe + CONSTANT height during rotation (no page jump)
  const track = document.getElementById('tstTrack');
  if (track) {
    const slides = [...track.querySelectorAll('.tst__q')];
    const dotsWrap = document.getElementById('tstDots');
    const vp = track.parentElement;
    let idx = 0, timer, baseH = 0, w = () => track.clientWidth;
    slides.forEach((_, i) => { const b = document.createElement('button'); b.type = 'button'; if (!i) b.classList.add('on'); b.addEventListener('click', (e) => { e.preventDefault(); goTo(i, true); }); dotsWrap.appendChild(b); });
    const moreBtns = slides.map((s) => s.querySelector('.tst__more'));
    function checkTrunc(){ slides.forEach((s, i) => { if (!moreBtns[i] || s.classList.contains('expanded')) return; const bq = s.querySelector('blockquote'); moreBtns[i].classList.toggle('hidden', bq.scrollHeight <= bq.clientHeight + 2); }); }
    function setBase(){ baseH = 0; slides.forEach((s) => { if (!s.classList.contains('expanded')) baseH = Math.max(baseH, s.offsetHeight); }); }
    function applyH(){ const s = slides[idx]; vp.style.height = (s.classList.contains('expanded') ? s.offsetHeight : baseH) + 'px'; }
    function collapseAll(){ slides.forEach((s, j) => { if (s.classList.contains('expanded')) { s.classList.remove('expanded'); if (moreBtns[j]) moreBtns[j].textContent = 'קרא עוד'; } }); }
    moreBtns.forEach((btn, i) => { if (!btn) return; btn.addEventListener('click', (e) => { e.preventDefault(); const exp = slides[i].classList.toggle('expanded'); btn.textContent = exp ? 'הצג פחות' : 'קרא עוד'; if (exp) clearInterval(timer); else restart(); applyH(); }); });
    function setActive(i){ idx = i; [...dotsWrap.children].forEach((d, j) => d.classList.toggle('on', j === i)); }
    function place(off){ track.style.transform = 'translateX(' + (-idx * w() + (off || 0)) + 'px)'; }
    function goTo(i, user){ collapseAll(); idx = (i + slides.length) % slides.length; track.style.transition = ''; place(0); setActive(idx); applyH(); if (user) restart(); }
    function restart(){ clearInterval(timer); if (slides.length > 1) timer = setInterval(() => goTo(idx + 1, false), 9000); }
    const prev = document.getElementById('tstPrev'), next = document.getElementById('tstNext');
    if (next) next.addEventListener('click', (e) => { e.preventDefault(); goTo(idx + 1, true); });
    if (prev) prev.addEventListener('click', (e) => { e.preventDefault(); goTo(idx - 1, true); });
    let x0 = null;
    track.addEventListener('touchstart', (e) => { x0 = e.touches[0].clientX; track.style.transition = 'none'; clearInterval(timer); }, { passive: true });
    track.addEventListener('touchmove', (e) => { if (x0 === null) return; place(e.touches[0].clientX - x0); }, { passive: true });
    track.addEventListener('touchend', (e) => { if (x0 === null) return; const dx = e.changedTouches[0].clientX - x0; x0 = null; track.style.transition = ''; if (dx < -45) goTo(idx + 1, true); else if (dx > 45) goTo(idx - 1, true); else { place(0); restart(); } });
    function relayout(){ checkTrunc(); setBase(); applyH(); }
    addEventListener('resize', () => { track.style.transition = 'none'; place(0); relayout(); requestAnimationFrame(() => track.style.transition = ''); });
    addEventListener('load', relayout); setTimeout(relayout, 300);
    checkTrunc(); setBase(); place(0); applyH(); restart();
  }
</script>
