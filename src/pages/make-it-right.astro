---
import Base from '../layouts/Base.astro';

// Landing-page images — self-hosted locally (no external/CDN dependency)
const U = '/uploads/make-it-right';
const img = {
  card1: `${U}/card1-v2.webp`,  // pain section (top) -> consultation image
  plan: `${U}/plan-v3.webp`,    // under "מה כוללת הפגישה" -> desk + plans (logo removed)
  testi1: `${U}/testi1.webp`,
  testi2: `${U}/testi2.webp`,
  price: `${U}/price.webp`,
  priceDiscount: `${U}/price-discount.webp`,
  plans: [`${U}/plan1.webp`, `${U}/plan2.webp`, `${U}/plan3.webp`, `${U}/plan4.webp`, `${U}/plan5.webp`],
  profile: `${U}/profile.webp`,
};

// Lead form -> dedicated "Make it Right" Google Form (own sheet + "Make it Right" email)
const FORM = 'https://docs.google.com/forms/d/1YTo1-pe6hdSGmt2FguVZyuZjy687JVBzBITe-BSU070/formResponse';
const E = { first: 'entry.2033688937', last: 'entry.1850283958', email: 'entry.1838298814', phone: 'entry.260674859' };

const includePrep = [
  'שבוע לפני הפגישה – שליחת התוכנית האדריכלית בקובץ PDF, כדי שאוכל לנתח אותה ולזהות את הבעיות. אני בוחנת את התוכנית לא רק כשרטוט – אלא מתוך הבנה רחבה של איך תהליך כזה מתקדם בפועל, ואיך החלטות תכנוניות משפיעות על הביצוע, התקציב והחיים עצמם.',
  'מילוי שאלון מקדים כדי שקצת נכיר ואבין מה הצרכים, החלומות והתקציב שעומד לרשותכם.',
];
const includeMeeting = [
  'סקירת התוכנית האדריכלית – בפגישה אצביע על יתרונות וחסרונות בתוכנית הקיימת, תקבלו כיוון כללי על האפשרויות התכנוניות האופציונליות בהתאם לצרכים שלכם, ואם מדובר בדירת קבלן – אילו שדרוגים כדאי לדרוש ואיך למקסם את הפוטנציאל שלה.',
  'הערכת תקציב לעבודת קבלן, מטבח, נגרויות, ריצופים וכלים סניטריים, תאורה ועוד – כדי שתדעו למה לצפות וכיצד להיערך עם פחות הפתעות בדרך.',
  'הסבר על לו"ז וסדר העבודה בשיפוץ.',
];
const forWho = [
  'למי שנמצא רגע לפני חתימה על דירה ורוצה להיות בטוח שהתכנון טוב והדירה מתאימה לו',
  'למי שמתלבט בין שתי דירות (או יותר) ולא יודע איזו תכנית טובה יותר',
  'למי שמתכנן שיפוץ בבית קיים ורוצה לדעת אם ואיך אפשר לעשות את זה',
  'למי שרוצה לקבל החלטות מתוך ביטחון – ולא לגלות טעויות יקרות בשלב הביצוע',
  'למי שמבין שתכנון נכון הוא הבסיס לשקט נפשי בהמשך התהליך',
];
const notForWho = [
  'למי שמחפשים חוות דעת מהירה של כמה דקות',
  'למי שכבר סגורים על הכול ולא פתוחים לבחון אפשרויות',
  'למי שמחפשים פתרון עיצובי נקודתי בלבד ללא הסתכלות רחבה',
];
const faq = [
  ['האם שעתיים יספיקו?', 'כן! אני מגיעה לפגישה לאחר שעברתי לעומק על התכניות והשאלון שמילאתם.'],
  ['האם נקבל תכנית מתוקנת?', 'בפגישה אצביע על בעיות, פוטנציאל וכיוונים לשיפור, ובסופה תקבלו סיכום מסודר. תכנון מפורט ושרטוטים מלאים נעשים במסגרת ליווי מלא.'],
  ['האם הפגישה מחייבת להמשיך לליווי מלא?', 'לא. הפגישה עומדת בפני עצמה. עם זאת, עבור חלק מהלקוחות היא מהווה שלב ראשון בתהליך ליווי מלא.'],
  ['מה קורה אם נרצה להמשיך?', 'אם תבחרו להמשיך לליווי מלא בתוך 14 יום ממועד הפגישה – עלות פגישת הייעוץ תקוזז ממחיר התהליך.'],
];
---
<Base active="" solidNav={true} ogImage="/assets/og-make-it-right.jpg" title="Make it Right · שרון שגיא" description="פגישת ייעוץ תכנוני ממוקדת לפני רכישת דירה או שיפוץ – שעתיים שיעשו לכם סדר בראש וביטחון בקבלת ההחלטה.">

  <!-- HERO -->
  <header class="mr-hero">
    <div class="mr-hero__in">
      <h1>Make it Right<br>פגישת ייעוץ תכנוני לפני רכישה או שיפוץ</h1>
      <p class="mr-hero__lead">אתם מתרגשים לקראת קניית דירה או שיפוץ גדול, משקיעים זמן, כסף ואנרגיה – אבל עמוק בפנים יש סימן שאלה קטן: האם התכנון באמת מתאים לחיים שלנו? האם השינויים שאנחנו רוצים לעשות בכלל אפשריים ונכונים?</p>
      <p class="mr-hero__sub">כי טעויות תכנוניות לא תמיד רואים על הנייר, אבל מרגישים אותן כל יום אח"כ.</p>
      <p class="mr-hero__sub mr-hero__sub--2"><b>רגע לפני שאתם מתחייבים להחלטה גדולה ומשמעותית כזו</b> – תנו לעין מקצועית לבחון את התוכנית שלכם לעומק, כדי שתוכלו להתקדם בביטחון ובשקט נפשי.</p>
      <a href="#lead" class="mr-btn">מרגישים שזה השלב לעצור ולבדוק? אשמח לדבר</a>
    </div>
  </header>

  <!-- LEAD FORM 1 -->
  <section class="mr-lead" id="lead">
    <div class="wrap">
      <h2 class="mr-h">השאירו פרטים לתיאום שיחת היכרות</h2>
      <form class="mr-form" action={FORM} method="POST" target="mir_sink">
        <div class="mr-row">
          <label>שם פרטי<input type="text" name={E.first} required autocomplete="given-name" /></label>
          <label>שם משפחה<input type="text" name={E.last} required autocomplete="family-name" /></label>
        </div>
        <div class="mr-row">
          <label>מייל<input type="email" name={E.email} required autocomplete="email" dir="ltr" /></label>
          <label>נייד<input type="tel" name={E.phone} required autocomplete="tel" dir="ltr" /></label>
        </div>
        <button type="submit" class="mr-btn mr-form__btn">לתיאום שיחת היכרות</button>
        <p class="mr-form__msg" hidden></p>
      </form>
    </div>
  </section>

  <!-- PAIN -->
  <section class="mr-sec wrap">
    <div class="mr-pain">
      <div class="mr-pain__txt reveal">
        <p>אתם לא מצליחים לדמיין איך הקווים בתכנית מתורגמים למציאות,</p>
        <p>או שמשהו בתכנית לא יושב לכם בול – המטבח נראה קטן מדי, הסלון צפוף, ואיפה שמים פינת אוכל?</p>
        <p>אתם רוצים להיכנס לתהליך הזה בביטחון ולדעת שבחרתם נכון.</p>
        <p class="mr-muted">אז אתם מעלים את תכנית הדירה לקבוצות עיצוב בפייסבוק ומקבלים 20 תגובות ו-15 דעות שונות… חלקן אפילו לא מאנשי מקצוע.</p>
        <p class="mr-muted">כבר ראיתם כמה דירות והסתכלתם על כמה תכניות בניסיון למצוא את ה"אחת".</p>
      </div>
      <div class="mr-pain__img reveal"><img src={img.card1} alt="פגישת ייעוץ תכנוני" loading="lazy" /></div>
    </div>
  </section>

  <!-- PROMISE -->
  <section class="mr-promise">
    <div class="wrap reveal">
      <h2 class="mr-h mr-h--light">Make it Right – פגישת ייעוץ תכנוני ממוקדת לפני קנייה או שיפוץ</h2>
      <p>פגישה אחת שתעשה לכם המון סדר בראש וביטחון בקבלת החלטה.</p>
      <p>בשעתיים מרוכזות תקבלו בהירות מלאה לגבי התכנית – מה עובד ומה חשוב לשנות, איך להפוך את הבית לפונקציונלי, ולא פחות חשוב – הערכת התקציב והלו"ז, כדי שתדעו כיצד להיערך.</p>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="mr-included wrap">
    <h2 class="mr-h">מה כוללת הפגישה?</h2>
    <div class="mr-plan reveal"><img src={img.plan} alt="ניתוח תכנית אדריכלית" loading="lazy" /></div>
    <div class="mr-inc">
      <div class="mr-inc__col reveal">
        <h3>הכנה לפגישה</h3>
        <ul>{includePrep.map((x) => (<li>{x}</li>))}</ul>
      </div>
      <div class="mr-inc__col reveal">
        <h3>פגישת ייעוץ של שעתיים בביתך / אונליין <span>(ללקוחות מחוץ לאזור העבודה שלי)</span></h3>
        <ul>{includeMeeting.map((x) => (<li>{x}</li>))}</ul>
      </div>
    </div>
  </section>

  <!-- AFTER -->
  <section class="mr-sec wrap">
    <h2 class="mr-h">מה קורה אחרי הפגישה?</h2>
    <div class="mr-after reveal">
      <p>לאחר פגישת הייעוץ תקבלו סיכום מסודר עם ההמלצות, הדגשים המרכזיים והכוונה להמשך הדרך – כולל הערכות ללוחות זמנים ותקציב (לשיפוץ) או רשימת שדרוגים מומלצים בדירת קבלן.</p>
      <p>עבור חלק מהלקוחות, הפגישה עומדת בפני עצמה ומספקת בהירות לקבלת החלטות. עבור אחרים, היא מהווה שלב ראשון בתהליך ליווי מלא – שבו אנחנו עולים שלב לתכנון מפורט ומדויק והובלת הפרויקט מול כלל אנשי המקצוע.</p>
      <p>בבחירה להמשיך לליווי מלא בתוך 14 יום ממועד הפגישה – עלות פגישת הייעוץ תקוזז ממחיר התהליך.</p>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="mr-sec mr-sec--tight wrap">
    <h2 class="mr-h">מה מספרים הלקוחות שלי?</h2>
    <p class="mr-sub">במהלך השנים ליוויתי משפחות בתהליכי תכנון, שיפוץ ובנייה, ועזרתי להן לקבל החלטות טובות יותר, להימנע מטעויות יקרות וליצור בתים שמתאימים באמת לצרכים שלהן.</p>
    <p class="mr-note mr-note--top">*ההמלצות מתייחסות לפרויקטים שבוצעו במסגרת השותפות ב־Two studio.</p>
    <div class="mr-testi reveal">
      <img src={img.testi1} alt="המלצות לקוחות" loading="lazy" />
      <img src={img.testi2} alt="המלצות לקוחות" loading="lazy" />
    </div>
  </section>

  <!-- WHAT I SPOT -->
  <section class="mr-sec wrap">
    <h2 class="mr-h">אז מה אני מזהה תוך דקה בתכניות?</h2>
    <div class="mr-gallery reveal">
      {img.plans.map((s) => (<img src={s} alt="ניתוח תכנית" loading="lazy" />))}
    </div>
  </section>

  <!-- PRICE -->
  <section class="mr-price">
    <div class="wrap reveal">
      <h2 class="mr-h">המחיר ל-Make it Right – פגישת ייעוץ תכנוני הוא</h2>
      <div class="mr-price__box">
        <span class="mr-price__old">1,500 ₪</span>
        <div class="mr-price__num">1,200 <span>₪</span></div>
        <p class="mr-price__tag">מחיר השקה – ל-5 הראשונים בלבד!</p>
      </div>
      <p class="mr-big">השקעה קטנה לפני החלטה גדולה ומשמעותית!</p>
      <p>אני מקבלת רק 4 לקוחות בחודש במסלול הזה, כדי שאוכל לעשות הכנה רצינית ומעמיקה לפני כל פגישה. לכן אם חשוב לכם לא לבזבז זמן יקר ולקבל החלטה חכמה – השאירו פרטים לתיאום שיחת היכרות קצרה.</p>
      <a href="#lead2" class="mr-btn mr-btn--light">לתיאום שיחת היכרות</a>
    </div>
  </section>

  <!-- LEAD FORM 2 -->
  <section class="mr-lead" id="lead2">
    <div class="wrap">
      <form class="mr-form" action={FORM} method="POST" target="mir_sink">
        <div class="mr-row">
          <label>שם פרטי<input type="text" name={E.first} required autocomplete="given-name" /></label>
          <label>שם משפחה<input type="text" name={E.last} required autocomplete="family-name" /></label>
        </div>
        <div class="mr-row">
          <label>מייל<input type="email" name={E.email} required autocomplete="email" dir="ltr" /></label>
          <label>נייד<input type="tel" name={E.phone} required autocomplete="tel" dir="ltr" /></label>
        </div>
        <button type="submit" class="mr-btn mr-form__btn">לתיאום שיחת היכרות</button>
        <p class="mr-form__msg" hidden></p>
      </form>
    </div>
  </section>

  <!-- FOR WHOM -->
  <section class="mr-sec wrap">
    <div class="mr-fit">
      <div class="mr-fit__col reveal">
        <h3 class="mr-fit__yes">למי מתאימה הפגישה?</h3>
        <ul>{forWho.map((x) => (<li>{x}</li>))}</ul>
      </div>
      <div class="mr-fit__col reveal">
        <h3 class="mr-fit__no">למי היא פחות מתאימה?</h3>
        <ul>{notForWho.map((x) => (<li>{x}</li>))}</ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mr-sec wrap">
    <h2 class="mr-h">עוד שאלות שאולי עלו לכם</h2>
    <div class="mr-faq">
      {faq.map(([q, a]) => (
        <details class="mr-q">
          <summary>{q}<span class="mr-q__mark">+</span></summary>
          <p>{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- FINAL CTA + FORM 3 -->
  <section class="mr-final">
    <div class="wrap reveal">
      <h2 class="mr-h mr-h--light">אז אם אתם רוצים לעשות החלטה נכונה, בואו נעשה אותה יחד</h2>
      <p class="mr-lets">let's <span class="mr-lets__name">Make it Right</span></p>
      <p>השאירו פרטים ונקבע שיחה קצרה כדי להבין באיזה שלב אתם ומה הכי נכון עבורכם.</p>
      <form class="mr-form mr-form--light" action={FORM} method="POST" target="mir_sink">
        <div class="mr-row">
          <label>שם פרטי<input type="text" name={E.first} required autocomplete="given-name" /></label>
          <label>שם משפחה<input type="text" name={E.last} required autocomplete="family-name" /></label>
        </div>
        <div class="mr-row">
          <label>מייל<input type="email" name={E.email} required autocomplete="email" dir="ltr" /></label>
          <label>נייד<input type="tel" name={E.phone} required autocomplete="tel" dir="ltr" /></label>
        </div>
        <button type="submit" class="mr-btn mr-form__btn">לתיאום שיחת היכרות</button>
        <p class="mr-form__msg" hidden></p>
      </form>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="mr-about">
    <div class="wrap mr-about__in">
      <div class="mr-about__img reveal"><img src={img.profile} alt="שרון שגיא" loading="lazy" /></div>
      <div class="mr-about__txt reveal">
        <p class="mr-eyebrow">אם אתם עדיין לא מכירים אותי – זה הזמן :)</p>
        <h2 class="mr-h">נעים להכיר</h2>
        <p>אני שרון שגיא, מעצבת פנים המתמחה בתכנון וליווי שיפוצים ובתים בבנייה.</p>
        <p>עוד כילדה נמשכתי לעולם הזה – הייתי משנה שוב ושוב את סידור ועיצוב החדר שלי :)</p>
        <p>לפני שהגעתי לעיצוב פנים עסקתי בכלל בייעוץ גנטי – תחום שלימד אותי להקשיב, לחשוב לעומק, לראות את התמונה המלאה ולשים לב לכל פרט קטן. היום אני מביאה בדיוק את אותה גישה גם לתכנון בתים.</p>
        <p>אני מאמינה שבית טוב מתחיל הרבה לפני בחירת צבעים וחומרים – הוא מתחיל בתכנון מדויק, בהבנת הצרכים וההרגלים של המשפחה וביצירת פתרונות חכמים שמאפשרים לבית לעבוד באמת ביום-יום.</p>
        <p>אני אוהבת את החיבור בין חשיבה תכנונית ופתרון בעיות לבין החלק היצירתי של בחירת חומרים, צבעים והלבשת הבית – וכך נוצרים בתים שהם גם פונקציונליים ונוחים לחיים, וגם מעוצבים ומלאי אופי.</p>
        <p class="mr-lead-line">אז בואו נצא לדרך יחד 💜</p>
      </div>
    </div>
  </section>

  <iframe name="mir_sink" title="submit" style="display:none"></iframe>

  <style>
    /* keep the logo, hide only the site menu links + hamburger */
    :global(#navLinks),:global(#navToggle){display:none !important}

    .mr-btn{display:inline-block;background:var(--accent);color:#fff;padding:16px 34px;border-radius:8px;font-size:1.08rem;font-weight:500;transition:.2s;border:none;cursor:pointer;line-height:1.4;box-shadow:0 8px 20px rgba(140,70,48,.28)}
    @media(hover:hover){.mr-btn:hover{background:var(--accent-deep);transform:translateY(-2px);box-shadow:0 12px 26px rgba(140,70,48,.34)}}
    .mr-btn:active{transform:translateY(0)}
    .mr-btn--light{background:#fff;color:var(--accent-deep);box-shadow:0 8px 20px rgba(40,25,15,.18)}
    @media(hover:hover){.mr-btn--light:hover{background:#fff;color:var(--accent);transform:translateY(-2px)}}
    .mr-h{font-family:var(--serif);font-weight:300;font-size:clamp(1.8rem,4.3vw,2.8rem);line-height:1.14;color:var(--ink);text-align:center}
    .mr-h--light{color:#fff}
    .mr-sub{text-align:center;color:var(--ink-soft);max-width:64ch;margin:14px auto 0;font-size:1.1rem;line-height:1.7}
    .mr-note{text-align:center;color:var(--ink-soft);opacity:.8;font-size:.82rem;margin-top:10px}
    .mr-note--top{margin-top:8px;margin-bottom:6px}
    .mr-eyebrow{font-family:var(--lat);font-style:italic;color:var(--accent-deep);font-size:1.1rem}
    .mr-sec{padding:8vh 0}
    .mr-sec--tight{padding-top:0}

    .mr-hero{background:var(--band);padding:6vh var(--pad) 11vh;text-align:center}
    .mr-hero__in{max-width:900px;margin:0 auto}
    .mr-hero h1{font-family:var(--serif);font-weight:300;font-size:clamp(2rem,5vw,3.3rem);line-height:1.16;margin:14px 0 0;color:var(--ink)}
    .mr-hero__lead{font-size:clamp(1.05rem,2.1vw,1.32rem);color:#5a4433;max-width:52ch;margin:22px auto 0;line-height:1.7}
    .mr-hero__sub{color:#5a4433;max-width:56ch;margin:16px auto 0;line-height:1.8}
    .mr-hero__sub--2{margin:14px auto 32px}
    .mr-hero__sub b{color:var(--accent-deep);font-weight:600}

    .mr-lead{padding:9vh 0;background:var(--bg)}
    .mr-form{max-width:620px;margin:28px auto 0}
    .mr-form--light{--fld:#fff}
    .mr-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px}
    .mr-form label{display:flex;flex-direction:column;gap:8px;font-size:.9rem;color:var(--ink-soft)}
    .mr-form--light label{color:#f4e6de}
    .mr-form input{border:1px solid #d9c8bb;background:#fff;border-radius:6px;padding:13px 15px;font-family:inherit;font-size:1rem;color:var(--ink);transition:.2s}
    .mr-form input:focus{outline:none;border-color:var(--accent)}
    .mr-form__btn{width:100%;margin-top:10px;border:none;font-size:1.1rem;font-weight:500;letter-spacing:.01em}
    .mr-form--light .mr-form__btn{background:#fff;color:var(--accent-deep);box-shadow:0 8px 20px rgba(40,25,15,.22)}
    @media(hover:hover){.mr-form--light .mr-form__btn:hover{background:#fff;color:var(--accent)}}
    .mr-form__msg{text-align:center;margin-top:18px;font-size:1.05rem;color:var(--accent-deep)}
    .mr-form--light .mr-form__msg{color:#fff}

    .mr-pain{display:grid;grid-template-columns:1.15fr .85fr;gap:clamp(28px,5vw,56px);align-items:center}
    .mr-pain__txt p{color:var(--ink-soft);line-height:1.9;font-size:1.08rem;margin-bottom:.7em}
    .mr-muted{opacity:.85}
    .mr-pain__img img{width:100%;border-radius:6px;display:block;aspect-ratio:5/4;object-fit:cover}

    .mr-promise{background:var(--accent);color:#fff;text-align:center;padding:10vh var(--pad)}
    .mr-promise p{max-width:60ch;margin:1em auto 0;font-size:1.12rem;line-height:1.8;color:#fbeee7}
    .mr-promise .mr-h{margin-bottom:.2em}

    .mr-included{padding-top:9vh}
    .mr-inc{display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-top:40px}
    .mr-inc__col{background:#fff;border:1px solid #E8D7CD;border-radius:10px;padding:30px 28px}
    .mr-inc__col h3{font-family:var(--serif);font-weight:500;font-size:1.3rem;color:var(--accent-deep);margin-bottom:16px}
    .mr-inc__col h3 span{display:block;font-family:var(--sans,inherit);font-size:.85rem;color:var(--ink-soft);font-weight:400;margin-top:4px}
    .mr-inc__col ul{list-style:none;padding:0;margin:0}
    .mr-inc__col li{position:relative;padding-inline-start:22px;margin-bottom:14px;color:var(--ink-soft);line-height:1.8}
    .mr-inc__col li::before{content:'';position:absolute;inset-inline-start:0;top:.7em;width:8px;height:8px;border-radius:50%;background:var(--accent)}
    .mr-plan{margin:32px auto 6px;max-width:760px}
    .mr-plan img{width:100%;border-radius:6px;display:block}

    .mr-after{background:#fff;border:1px solid #E8D7CD;border-radius:10px;padding:34px 32px;margin:36px auto 0;max-width:900px}
    .mr-after p{margin:0 0 1em;color:var(--ink-soft);line-height:1.9;font-size:1.06rem}
    .mr-after p:last-child{margin-bottom:0}

    .mr-testi{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-top:32px}
    .mr-testi img{width:100%;border-radius:6px;display:block}

    .mr-gallery{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-top:36px}
    .mr-gallery img{width:100%;border-radius:6px;display:block;aspect-ratio:1/1;object-fit:cover}

    .mr-price{background:var(--band);text-align:center;padding:11vh var(--pad)}
    .mr-price__box{margin:26px auto 10px}
    .mr-price__old{display:inline-block;font-size:1.5rem;color:#7d6552;text-decoration:line-through;text-decoration-color:var(--accent);text-decoration-thickness:2px;opacity:.75}
    .mr-price__num{font-family:var(--serif);font-size:clamp(3.2rem,8.5vw,5.2rem);line-height:1;color:var(--accent-deep);margin:8px 0 14px}
    .mr-price__num span{font-size:.42em;vertical-align:middle}
    .mr-price__tag{display:inline-block;background:var(--accent);color:#fff;padding:10px 22px;border-radius:8px;font-weight:500;font-size:1rem;margin:0!important}
    .mr-big{font-family:var(--serif);font-size:clamp(1.75rem,4.2vw,2.5rem);font-weight:600;color:var(--accent-deep);margin:.55em auto .3em!important}
    .mr-price p{max-width:58ch;margin:0 auto 1em;color:#5a4433;line-height:1.8;font-size:1.08rem}
    .mr-price .mr-btn--light{margin-top:14px}

    .mr-fit{display:grid;grid-template-columns:1fr 1fr;gap:28px}
    .mr-fit__col{background:#fff;border:1px solid #E8D7CD;border-radius:10px;padding:30px 28px}
    .mr-fit__col h3{font-family:var(--serif);font-weight:500;font-size:1.35rem;margin-bottom:16px}
    .mr-fit__yes{color:var(--accent-deep)}
    .mr-fit__no{color:#9a8b7d}
    .mr-fit__col ul{list-style:none;padding:0;margin:0}
    .mr-fit__col li{position:relative;padding-inline-start:24px;margin-bottom:12px;color:var(--ink-soft);line-height:1.7}
    .mr-fit__yes~ul li::before,.mr-fit__col li::before{content:'';position:absolute;inset-inline-start:0;top:.55em;width:10px;height:10px;border-radius:50%;background:var(--band)}

    .mr-faq{max-width:760px;margin:36px auto 0}
    .mr-q{border-bottom:1px solid #e2d3c8}
    .mr-q summary{list-style:none;cursor:pointer;padding:20px 0;font-family:var(--serif);font-size:1.18rem;color:var(--ink);display:flex;justify-content:space-between;align-items:center;gap:18px}
    .mr-q summary::-webkit-details-marker{display:none}
    .mr-q__mark{color:var(--accent);font-size:1.5rem;transition:.3s;flex:0 0 auto}
    .mr-q[open] .mr-q__mark{transform:rotate(45deg)}
    .mr-q p{color:var(--ink-soft);line-height:1.8;padding:0 0 22px;margin:0}

    .mr-final{background:var(--accent);color:#fff;text-align:center;padding:11vh var(--pad)}
    .mr-final p{max-width:56ch;margin:.6em auto 0;font-size:1.1rem;line-height:1.7;color:#fbeee7}
    .mr-lets{font-family:var(--lat);font-style:italic;font-size:clamp(1.6rem,4vw,2.4rem);color:#fff!important;margin:.2em auto!important}
    .mr-lets__name{font-weight:600;font-size:1.22em;color:#fff;letter-spacing:.01em}

    .mr-about{background:var(--band);padding:11vh 0}
    .mr-about__in{display:grid;grid-template-columns:.8fr 1.2fr;gap:clamp(30px,5vw,64px);align-items:center}
    .mr-about__img img{width:100%;border-radius:6px;aspect-ratio:4/5;object-fit:cover;box-shadow:0 24px 55px rgba(38,32,25,.18)}
    .mr-about__txt .mr-h{text-align:right;margin-top:6px}
    .mr-about__txt p{color:#5a4433;line-height:1.9;margin-top:1em;font-size:1.05rem}
    .mr-lead-line{font-family:var(--serif);font-size:1.25rem}

    @media(max-width:820px){
      .mr-hero{padding-top:5vh}
      .mr-pain,.mr-inc,.mr-fit,.mr-about__in{grid-template-columns:1fr}
      .mr-pain__img{order:-1}
      .mr-testi{grid-template-columns:1fr}
      .mr-gallery{grid-template-columns:repeat(2,1fr)}
      .mr-row{grid-template-columns:1fr}
    }
  </style>

  <script is:inline>
    (function(){
      var forms = document.querySelectorAll('.mr-form');
      var iframe = document.querySelector('iframe[name="mir_sink"]');
      var pending = null;
      forms.forEach(function(f){
        f.addEventListener('submit', function(){ pending = f; });
      });
      if (iframe) iframe.addEventListener('load', function(){
        if(!pending) return;
        var msg = pending.querySelector('.mr-form__msg');
        pending.querySelectorAll('.mr-row, .mr-form__btn').forEach(function(el){ el.style.display='none'; });
        if(msg){ msg.hidden=false; msg.textContent='תודה! קיבלתי את הפרטים ואחזור אלייך בהקדם 💜'; }
        pending = null;
      });
      var io = new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-in');io.unobserve(e.target);}})},{threshold:.12});
      document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
    })();
  </script>
</Base>
