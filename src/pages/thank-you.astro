---
import Base from '../layouts/Base.astro';
---
<Base active="" solidNav={true} title="תודה! · שרון שגיא" description="קיבלנו את הפרטים שלך – נחזור אלייך בהקדם.">
  <section class="ty">
    <div class="ty__in">
      <div class="ty__mark" aria-hidden="true">
        <svg viewBox="0 0 52 52" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="26" cy="26" r="23" opacity=".35"></circle>
          <path d="M16 27.5l7 7 14-16"></path>
        </svg>
      </div>

      <h1>תודה!</h1>
      <p class="ty__lead">קיבלתי את הפרטים שלך.</p>
      <p class="ty__sub">אחזור אלייך בהקדם לשיחת היכרות קצרה, כדי להבין באיזה שלב את ומה הכי נכון עבורך.<br />שעות הפעילות של הסטודיו: ימים א׳–ה׳, 9:00–18:00.</p>

      <div class="ty__btns">
        <button type="button" class="ty__btn ty__btn--ghost" id="tyBack">‹ חזרה לעמוד הקודם</button>
        <a href="/projects" class="ty__btn">לצפייה בפרויקטים</a>
      </div>

      <p class="ty__wa">רוצה לדבר עכשיו? <a href="https://wa.me/972523724032">שלחי לי הודעת וואטסאפ</a></p>
    </div>
  </section>

  <style>
    .ty{background:var(--band);padding:14vh var(--pad) 15vh;text-align:center}
    .ty__in{max-width:640px;margin:0 auto}
    .ty__mark{width:72px;height:72px;margin:0 auto 26px;color:var(--accent-deep)}
    .ty__mark svg{width:100%;height:100%}
    .ty h1{font-family:var(--serif);font-weight:300;font-size:clamp(2.6rem,7vw,4.2rem);line-height:1.05;color:var(--ink)}
    .ty__lead{font-size:clamp(1.2rem,2.4vw,1.5rem);color:var(--accent-deep);margin-top:12px;font-weight:500}
    .ty__sub{color:#5a4433;line-height:1.9;margin-top:18px;font-size:1.05rem}
    .ty__btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:36px}
    .ty__btn{display:inline-block;background:var(--accent);color:#fff;padding:14px 30px;border-radius:8px;font-size:1rem;font-weight:500;border:none;cursor:pointer;font-family:inherit;transition:.2s;box-shadow:0 8px 20px rgba(140,70,48,.26)}
    @media(hover:hover){.ty__btn:hover{background:var(--accent-deep);transform:translateY(-2px)}}
    .ty__btn--ghost{background:transparent;color:var(--accent-deep);border:1px solid var(--accent-deep);box-shadow:none}
    @media(hover:hover){.ty__btn--ghost:hover{background:var(--accent-deep);color:#fff}}
    .ty__wa{margin-top:30px;font-size:.95rem;color:#6b5040}
    .ty__wa a{color:var(--accent-deep);text-decoration:underline;text-underline-offset:3px}
  </style>

  <script is:inline>
    document.getElementById('tyBack')?.addEventListener('click', function(){
      if (history.length > 1) history.back(); else location.href = '/';
    });
  </script>
</Base>
