        </span>
        <span class="fc-line">
          <svg class="fc-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M12 7.5V12l3 1.8"></path></svg>
          <span class="fc-val">שעות פעילות · א׳–ה׳ 9:00–18:00</span>
        </span>
      </div>
    </div>
  )}
  <div class="foot__bottom">
    <span>© {year} שרון שגיא · תכנון ועיצוב פנים</span>
  </div>
</footer>
