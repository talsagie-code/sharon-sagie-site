---
const { slim = false } = Astro.props;
const year = new Date().getFullYear();
---
<footer class={`foot${slim ? ' foot--slim' : ''}`}>
  {slim ? (
    <div class="foot__slim">
      <a class="foot__logo" href="/"><img src="/assets/logo-nav.png" alt="שרון שגיא" /><span class="foot__tag">interior design &amp; home planning</span></a>
      <div class="social">
        <a href="https://www.instagram.com/sharonsa.design_?igsh=MXYxMnpobjRveGN1dQ%3D%3D&utm_source=qr" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
        <a href="https://www.facebook.com/profile.php?id=100076946022571" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a>
      </div>
    </div>
  ) : (
    <div class="foot__top">
      <div class="foot__col">
        <div class="social">
          <a href="/" aria-label="לאתר הבית"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-7 9 7"></path><path d="M5 10v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-9"></path></svg></a>
          <a href="https://www.instagram.com/sharonsa.design_?igsh=MXYxMnpobjRveGN1dQ%3D%3D&utm_source=qr" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
          <a href="https://www.facebook.com/profile.php?id=100076946022571" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a>
        </div>
      </div>
      <div class="foot__logo"><img src="/assets/logo-nav.png" alt="שרון שגיא" /><span class="foot__tag">interior design &amp; home planning</span></div>
      <div class="foot__col foot__contact">
        <h5>בואו נדבר</h5>
        <a class="fc-line fc-link" href="https://wa.me/972523724032" aria-label="וואטסאפ 052-372-4032">
          <svg class="fc-ic fc-wa" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path></svg>
